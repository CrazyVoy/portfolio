async def save_edit(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Сохранение изменений"""
    user_id = update.effective_user.id
    edit_type = context.user_data.get('edit_type')

    if not edit_type:
        return

    if edit_type == "edit_name":
        user_profiles[user_id]['name'] = update.message.text
        await update.message.reply_text("Имя обновлено!")

    elif edit_type == "edit_age":
        try:
            age = int(update.message.text)
            if age < 10 or age > 99:
                await update.message.reply_text("Пожалуйста, введите реальный возраст (10-99):")
                return
            user_profiles[user_id]['age'] = age
            await update.message.reply_text("Возраст обновлён!")
        except ValueError:
            await update.message.reply_text("Пожалуйста, введите число:")
            return

    elif edit_type == "edit_photo":
        if update.message.photo:
            photo = update.message.photo[-1]
            photo_file = await photo.get_file()
            file_size = photo_file.file_size

            if file_size > 15 * 1024 * 1024:
                await update.message.reply_text(
                    "Фото слишком большое! Максимальный размер - 15 МБ.\n"
                    "Пожалуйста, отправьте фото меньшего размера:"
                )
                return

            user_profiles[user_id]['photo_id'] = photo.file_id
            await update.message.reply_text("Фото обновлено!")
        else:
            await update.message.reply_text("Пожалуйста, отправьте фото:")
            return

    elif edit_type == "edit_bio":
        user_profiles[user_id]['bio'] = update.message.text
        await update.message.reply_text("Описание обновлено!")

    # Очищаем тип редактирования
    context.user_data.pop('edit_type', None)


