async def handle_city_search_action(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик действий при поиске по городу"""
    query = update.callback_query
    await query.answer()

    user_id = update.effective_user.id
    data = query.data

    if data.startswith("city_like_"):
        # Лайк в поиске по городу
        liked_user_id = int(data.split("_")[2])

        likes[user_id].add(liked_user_id)
        if liked_user_id in user_profiles:
            user_profiles[liked_user_id]['likes_count'] += 1

        # Проверяем на взаимный лайк
        if user_id in likes.get(liked_user_id, set()):
            match_key = tuple(sorted((user_id, liked_user_id)))
            matches[match_key] = datetime.now()

            liked_user_name = user_profiles[liked_user_id]['name']
            current_user_name = user_profiles[user_id]['name']

            await query.edit_message_caption(
                caption=f"💕 *ВЗАИМНАЯ СИМПАТИЯ!*\n\n"
                        f"Вы и {liked_user_name} понравились друг другу!\n\n"
                        f"Начните общение через /chats",
                parse_mode='Markdown'
            )

            try:
                await context.bot.send_message(
                    chat_id=liked_user_id,
                    text=f"💕 *ВЗАИМНАЯ СИМПАТИЯ!*\n\n"
                         f"Вы и {current_user_name} понравились друг другу!\n\n"
                         f"Начните общение через /chats",
                    parse_mode='Markdown'
                )
            except Exception as e:
                logger.error(f"Не удалось отправить уведомление: {e}")
        else:
            await query.edit_message_caption(
                caption="❤️ Симпатия отправлена!",
                parse_mode='Markdown'
            )

        # Переходим к следующему профилю
        context.user_data['current_city_index'] += 1
        await asyncio.sleep(2)
        await show_next_city_profile(update, context)

    elif data.startswith("city_skip_"):
        # Пропуск в поиске по городу
        skipped_user_id = int(data.split("_")[2])
        likes[user_id].add(skipped_user_id)

        context.user_data['current_city_index'] += 1
        await show_next_city_profile(update, context)

    elif data == "city_next":
        context.user_data['current_city_index'] += 1
        await show_next_city_profile(update, context)

    elif data == "back_to_city_select":
        await query.delete_message()
        await search_city(update, context)


