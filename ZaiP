    query = update.callback_query
    await query.answer()

    user_id = update.effective_user.id
    partner_id = int(query.data.split("_")[2])

    # Проверяем, есть ли взаимная симпатия
    match_key = tuple(sorted((user_id, partner_id)))
    if match_key not in matches:
        await query.edit_message_text("Сначала нужно взаимно понравиться друг другу!")
        return

    # Устанавливаем активный чат
    active_chats[user_id] = partner_id

