# Настройка логирования
logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    level=logging.INFO
)
logger = logging.getLogger(__name__)

# Состояния для ConversationHandler
NAME, AGE, GENDER, CITY, PHOTO, BIO, CONFIRM = range(7)

# Хранилище данных пользователей
user_profiles: Dict[int, Dict] = {}

# Хранилище симпатий: {user_id: set(liked_user_ids)}
likes: Dict[int, Set[int]] = defaultdict(set)

# Хранилище взаимных симпатий (matches)
matches: Dict[Tuple[int, int], datetime] = {}

# Хранилище сообщений между пользователями
# Структура: {(user1_id, user2_id): [{"from": user_id, "text": "message", "time": datetime}, ...]}
chat_messages: Dict[Tuple[int, int], List[Dict]] = defaultdict(list)

# Хранилище активных чатов пользователей {user_id: partner_id}
active_chats: Dict[int, int] = {}

# Популярные города для быстрого выбора
POPULAR_CITIES = [
    "Москва", "Санкт-Петербург", "Новосибирск", "Екатеринбург", "Казань",
    "Нижний Новгород", "Челябинск", "Самара", "Омск", "Ростов-на-Дону",
    "Уфа", "Красноярск", "Саратов", "Пермь", "Волгоград"
]


class UserProfile:
    """Класс для хранения профиля пользователя"""

    def __init__(self):
        self.name = None
        self.age = None
        self.gender = None
        self.city = None
        self.photo_id = None
        self.bio = None
        self.created_at = None
        self.likes_count = 0  # Количество полученных лайков

    def to_dict(self):
        return {
            'name': self.name,
            'age': self.age,
            'gender': self.gender,
            'city': self.city,
            'photo_id': self.photo_id,
            'bio': self.bio,
            'created_at': self.created_at,
            'likes_count': self.likes_count
        }


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Начало создания анкеты"""
    user = update.effective_user

    # Проверяем, есть ли у пользователя активный чат
    if update.effective_user.id in active_chats:
        await show_active_chat(update, context)
        return ConversationHandler.END

    await update.message.reply_text(
        f"Привет, {user.first_name}! Давай создадим твою анкету.\n"
        "Введите ваше имя:"
    )
    return NAME


async def get_name(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Получение имени"""
    context.user_data['profile'] = UserProfile()
    context.user_data['profile'].name = update.message.text

    await update.message.reply_text("Сколько вам лет?")
    return AGE


async def get_age(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Получение возраста"""
    try:
        age = int(update.message.text)
        if age < 10 or age > 99:
            await update.message.reply_text("Пожалуйста, введите реальный возраст (10-99):")
            return AGE
    except ValueError:
        await update.message.reply_text("Пожалуйста, введите число:")
        return AGE

    context.user_data['profile'].age = age

    keyboard = [
        [
            InlineKeyboardButton("Мужской", callback_data="male"),
            InlineKeyboardButton("Женский", callback_data="female")
        ],
        [
            InlineKeyboardButton("Другой", callback_data="other")
        ]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)

    await update.message.reply_text("Выберите ваш пол:", reply_markup=reply_markup)
    return GENDER


async def get_gender(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Получение пола"""
    query = update.callback_query
    await query.answer()

    gender_map = {
        "male": "Мужской",
        "female": "Женский",
        "other": "Другой"
    }

    context.user_data['profile'].gender = gender_map[query.data]

    await query.edit_message_text(text=f"Пол: {gender_map[query.data]}")

    # Создаем клавиатуру с популярными городами
    keyboard = []
    row = []
    for i, city in enumerate(POPULAR_CITIES, 1):
        row.append(InlineKeyboardButton(city, callback_data=f"city_{city}"))
        if i % 3 == 0:
            keyboard.append(row)
            row = []
    if row:
        keyboard.append(row)
    keyboard.append([InlineKeyboardButton("✏️ Ввести другой город", callback_data="city_other")])

    reply_markup = InlineKeyboardMarkup(keyboard)

    await query.message.reply_text(
        "Выберите ваш город или введите свой:",
        reply_markup=reply_markup
    )
    return CITY


async def get_city(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Получение города"""
    query = update.callback_query
    await query.answer()

    if query.data == "city_other":
        await query.edit_message_text(
            "Введите название вашего города:"
        )
        return CITY

    # Получаем город из callback_data (убираем префикс "city_")
    city = query.data[5:]  # "city_Москва" -> "Москва"
    context.user_data['profile'].city = city

    await query.edit_message_text(text=f"Город: {city}")
    await query.message.reply_text(
        "Отправьте ваше фото (максимум 15 МБ).\n"
        "Поддерживаемые форматы: JPEG, PNG"
    )
    return PHOTO


async def get_city_text(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Получение города из текстового сообщения"""
    city = update.message.text.strip()
    if len(city) < 2:
        await update.message.reply_text("Название города слишком короткое. Введите ещё раз:")
        return CITY

    context.user_data['profile'].city = city

    await update.message.reply_text(
        f"Город: {city}\n\n"
        "Отправьте ваше фото (максимум 15 МБ).\n"
        "Поддерживаемые форматы: JPEG, PNG"
    )
    return PHOTO


async def get_photo(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Получение фото с проверкой размера"""
    if update.message.photo:
        photo = update.message.photo[-1]

        # Получаем информацию о файле
        photo_file = await photo.get_file()
        file_size = photo_file.file_size

        # Проверяем размер файла (15 МБ = 15 * 1024 * 1024 байт)
        if file_size > 15 * 1024 * 1024:
            await update.message.reply_text(
                "Фото слишком большое! Максимальный размер - 15 МБ.\n"
                "Пожалуйста, отправьте фото меньшего размера:"
            )
            return PHOTO

        # Сохраняем file_id фото (в Telegram можно хранить только file_id)
        context.user_data['profile'].photo_id = photo.file_id

        await update.message.reply_text("Фото получено! Теперь напишите краткую информацию о себе:")
        return BIO

    else:
        await update.message.reply_text("Пожалуйста, отправьте фото:")
        return PHOTO


