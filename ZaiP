async def handle_chat_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик сообщений в чате"""
    user_id = update.effective_user.id

    # Проверяем, есть ли активный чат
    if user_id not in active_chats:
        return

    # Проверяем, ждем ли мы сообщение от пользователя
    if not context.user_data.get('waiting_for_message', False):
        return

    partner_id = active_chats[user_id]

    # Получаем текст сообщения
    message_text = update.message.text.strip()

    if not message_text:
        await update.message.reply_text("Сообщение не может быть пустым!")
        return

    if message_text.startswith('/'):
        await update.message.reply_text("В чате нельзя использовать команды. Просто пишите сообщения!")
        return

    # Сохраняем сообщение
    chat_key = tuple(sorted((user_id, partner_id)))
    chat_messages[chat_key].append({
        'from': user_id,
        'text': message_text,
        'time': datetime.now()
    })

    # Ограничиваем историю сообщений (последние 100)
    if len(chat_messages[chat_key]) > 100:
        chat_messages[chat_key] = chat_messages[chat_key][-100:]

    # Отправляем сообщение партнеру
    user_profile = user_profiles[user_id]
    user_name = user_profile['name']

    try:
        await context.bot.send_message(
            chat_id=partner_id,
            text=f"💌 *Новое сообщение от {user_name}:*\n\n{message_text}\n\n"
                 f"_Ответьте через /chats_",
            parse_mode='Markdown'
        )
    except Exception as e:
        logger.error(f"Не удалось отправить сообщение партнеру: {e}")

    # Подтверждаем отправку
    await update.message.reply_text(
        f"✅ *Сообщение отправлено!*\n\n"
        f"{message_text}",
        parse_mode='Markdown'
    )

    # Сбрасываем флаг ожидания
    context.user_data['waiting_for_message'] = False

    # Показываем обновленный чат
    await show_active_chat(update, context)


