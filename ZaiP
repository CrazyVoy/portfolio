async def error_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик ошибок"""
    logger.error(f"Ошибка: {context.error}")

    if isinstance(context.error, ValueError):
        await update.message.reply_text("Произошла ошибка. Пожалуйста, попробуйте снова.")
    elif isinstance(context.error, Exception):
        await update.message.reply_text("Произошла непредвиденная ошибка.")


import asyncio


def main():
    """Запуск бота"""
    # Токен вашего бота
    TOKEN = " "

    # Создаём приложение
    application = Application.builder().token(TOKEN).build()

    # Создаём ConversationHandler для анкеты
    conv_handler = ConversationHandler(
        entry_points=[CommandHandler('start', start)],
        states={
            NAME: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_name)],
            AGE: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_age)],
            GENDER: [CallbackQueryHandler(get_gender)],
            CITY: [
                CallbackQueryHandler(get_city, pattern=r"^city_"),
                MessageHandler(filters.TEXT & ~filters.COMMAND, get_city_text)
            ],
            PHOTO: [MessageHandler(filters.PHOTO, get_photo)],
            BIO: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_bio)],
            CONFIRM: [CallbackQueryHandler(confirm_profile)]
        },
        fallbacks=[CommandHandler('cancel', cancel)],
        allow_reentry=True
    )

    # Добавляем обработчики
    application.add_handler(conv_handler)
    application.add_handler(CommandHandler('profile', show_profile))
    application.add_handler(CommandHandler('discover', discover_profiles))
    application.add_handler(CommandHandler('likes', show_likes))
    application.add_handler(CommandHandler('matches', show_matches))
    application.add_handler(CommandHandler('chats', show_chats))
    application.add_handler(CommandHandler('edit', edit_profile))
    application.add_handler(CommandHandler('search', search_city))
    application.add_handler(CommandHandler('help', help_command))

    # Команда для отмены отправки сообщения в чате
    application.add_handler(CommandHandler('cancel', cancel_chat_message))

    # Обработчики callback запросов
    application.add_handler(CallbackQueryHandler(handle_discovery_action, pattern=r"^(like_|skip_|discovery_)"))
    application.add_handler(CallbackQueryHandler(handle_city_search_action,
                                                 pattern=r"^(city_like_|city_skip_|city_next|back_to_city_select)"))
    application.add_handler(CallbackQueryHandler(show_city_results, pattern=r"^search_"))
    application.add_handler(CallbackQueryHandler(view_like_detail, pattern=r"^view_like_"))
    application.add_handler(CallbackQueryHandler(like_back_handler, pattern=r"^like_back_"))
    application.add_handler(CallbackQueryHandler(start_chat, pattern=r"^chat_with_"))
    application.add_handler(CallbackQueryHandler(handle_chat_action,
                                                 pattern=r"^(send_message|exit_chat|back_to_chat|view_profile_|block_user_)"))
    application.add_handler(
        CallbackQueryHandler(edit_handler, pattern=r"^edit_(name|age|gender|city|photo|bio|cancel)$"))
    application.add_handler(CallbackQueryHandler(save_gender_edit, pattern=r"^gender_"))
    application.add_handler(CallbackQueryHandler(save_city_edit, pattern=r"^edit_city_"))

    # Обработчики текстовых сообщений для редактирования
    application.add_handler(MessageHandler(
        filters.TEXT & ~filters.COMMAND & filters.Regex(
            r'^(?!.*(cancel|help|start|profile|discover|likes|matches|chats|edit|search)).*$'),
        save_edit
    ))

    # Обработчик для фото при редактировании
    application.add_handler(MessageHandler(filters.PHOTO, save_edit))

    # Обработчик для текстового ввода города при редактировании
    application.add_handler(MessageHandler(
        filters.TEXT & ~filters.COMMAND,
        save_city_text_edit
    ))

    # Обработчик сообщений в чате
    application.add_handler(MessageHandler(
        filters.TEXT & ~filters.COMMAND,
        handle_chat_message
    ))

    # Обработчик ошибок
    application.add_error_handler(error_handler)

    # Запускаем бота
    print("Бот запущен...")
    application.run_polling(allowed_updates=Update.ALL_TYPES)


if __name__ == '__main__':
    main()
