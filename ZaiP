async def confirm_profile(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Подтверждение анкеты"""
    query = update.callback_query
    await query.answer()

    if query.data == "confirm_yes":
        # Сохраняем профиль
        user_id = update.effective_user.id
        profile = context.user_data['profile']
        user_profiles[user_id] = profile.to_dict()

        await query.edit_message_caption(
            caption="✅ *Анкета успешно сохранена!*\n\n"
                    "Используйте /profile для просмотра своей анкеты\n"
                    "Используйте /edit для изменения анкеты\n"
                    "Используйте /discover для поиска анкет\n"
                    "Используйте /likes для просмотра симпатий\n"
                    "Используйте /matches для просмотра и общения с взаимными симпатиями",
            parse_mode='Markdown'
        )

        # Очищаем временные данные
        context.user_data.clear()
        return ConversationHandler.END

    else:
        # Начинаем заново
        await query.edit_message_caption(caption="Давайте начнём заново. Введите ваше имя:")
        return NAME


async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Отмена создания анкеты"""
    await update.message.reply_text("Создание анкеты отменено.")
    context.user_data.clear()
    return ConversationHandler.END


async def show_profile(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Показать свою анкету"""
    user_id = update.effective_user.id

    if user_id not in user_profiles:
        await update.message.reply_text(
            "У вас ещё нет анкету. Создайте её с помощью команды /start"
        )
        return

    profile = user_profiles[user_id]

    # Считаем статистику
    total_likes = profile['likes_count']
    given_likes = len(likes.get(user_id, set()))
    user_matches = sum(1 for (u1, u2) in matches.keys() if u1 == user_id or u2 == user_id)

    profile_text = (
        "📋 *Ваша анкета:*\n\n"
        f"👤 *Имя:* {profile['name']}\n"
        f"🎂 *Возраст:* {profile['age']}\n"
        f"⚧ *Пол:* {profile['gender']}\n"
        f"🏙️ *Город:* {profile['city']}\n"
        f"📝 *О себе:* {profile['bio']}\n"
        f"❤️ *Получено симпатий:* {total_likes}\n"
        f"🤍 *Отправлено симпатий:* {given_likes}\n"
        f"💕 *Взаимных симпатий:* {user_matches}\n"
        f"📅 *Создано:* {profile['created_at'].strftime('%d.%m.%Y %H:%M')}"
    )

    if profile['photo_id']:
        await update.message.reply_photo(
            photo=profile['photo_id'],
            caption=profile_text,
            parse_mode='Markdown'
        )
    else:
        await update.message.reply_text(profile_text, parse_mode='Markdown')


async def discover_profiles(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Поиск анкет для просмотра (с симпатиями)"""
    user_id = update.effective_user.id

    # Проверяем активный чат
    if user_id in active_chats:
        await show_active_chat(update, context)
        return

    if user_id not in user_profiles:
        await update.message.reply_text(
            "Сначала создайте анкету с помощью /start"
        )
        return

    # Находим анкеты, которые пользователь ещё не видел (не лайкал и не дизлайкал)
    user_likes = likes.get(user_id, set())

    # Исключаем свою анкету и уже лайкнутые
    available_profiles = []
    for uid, profile in user_profiles.items():
        if uid != user_id and uid not in user_likes:
            available_profiles.append((uid, profile))

    if not available_profiles:
        await update.message.reply_text(
            "Вы просмотрели все анкеты! Попробуйте позже или используйте /search для поиска по городу."
        )
        return

    # Выбираем случайную анкету для показа
    import random
    random_profile_id, random_profile = random.choice(available_profiles)

    # Сохраняем ID текущего просматриваемого профиля
    context.user_data['current_discovery_id'] = random_profile_id

    # Формируем текст анкеты
    profile_text = (
        f"👤 *{random_profile['name']}, {random_profile['age']}*\n"
        f"⚧ *Пол:* {random_profile['gender']}\n"
        f"🏙️ *Город:* {random_profile['city']}\n"
        f"📝 *О себе:* {random_profile['bio']}\n"
        f"❤️ *Симпатий:* {random_profile['likes_count']}"
    )

    # Создаем клавиатуру с действиями
    keyboard = [
        [
            InlineKeyboardButton("❤️ Нравится", callback_data=f"like_{random_profile_id}"),
            InlineKeyboardButton("➡️ Дальше", callback_data="discovery_next")
        ],
        [
            InlineKeyboardButton("🔍 Фильтр по городу", callback_data="discovery_filter"),
            InlineKeyboardButton("🚫 Пропустить", callback_data=f"skip_{random_profile_id}")
        ]
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)

    if random_profile['photo_id']:
        await update.message.reply_photo(
            photo=random_profile['photo_id'],
            caption=profile_text,
            parse_mode='Markdown',
            reply_markup=reply_markup
        )
    else:
        await update.message.reply_text(
            profile_text,
            parse_mode='Markdown',
            reply_markup=reply_markup
        )


async def handle_discovery_action(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик действий при просмотре анкет"""
    query = update.callback_query
    await query.answer()

    user_id = update.effective_user.id
    data = query.data

    if data.startswith("like_"):
        # Обработка лайка
        liked_user_id = int(data.split("_")[1])

        # Добавляем лайк
        likes[user_id].add(liked_user_id)

        # Увеличиваем счетчик лайков у получателя
        if liked_user_id in user_profiles:
            user_profiles[liked_user_id]['likes_count'] += 1

        # Проверяем на взаимный лайк
        if user_id in likes.get(liked_user_id, set()):
            # Создаем взаимную симпатию
            match_key = tuple(sorted((user_id, liked_user_id)))
            matches[match_key] = datetime.now()

            # Уведомляем обоих пользователей
            liked_user_name = user_profiles[liked_user_id]['name']
            current_user_name = user_profiles[user_id]['name']

            # Уведомление текущему пользователю
            await query.edit_message_caption(
                caption=f"💕 *ВЗАИМНАЯ СИМПАТИЯ!*\n\n"
                        f"Вы и {liked_user_name} понравились друг другу!\n\n"
                        f"Начните общение, используя команду /chats",
                parse_mode='Markdown'
            )

            # Уведомление другому пользователю (если бот может отправить сообщение)
            try:
                await context.bot.send_message(
                    chat_id=liked_user_id,
                    text=f"💕 *ВЗАИМНАЯ СИМПАТИЯ!*\n\n"
                         f"Вы и {current_user_name} понравились друг другу!\n\n"
                         f"Начните общение, используя команду /chats",
                    parse_mode='Markdown'
                )
            except Exception as e:
                logger.error(f"Не удалось отправить уведомление о взаимной симпатии: {e}")
        else:
            await query.edit_message_caption(
                caption="❤️ *Симпатия отправлена!*\n\n"
                        "Если пользователь ответит взаимностью, вы получите уведомление.",
                parse_mode='Markdown'
            )

        # Показываем следующую анкету через 2 секунды
        await asyncio.sleep(2)
        await discover_profiles(update, context)

    elif data.startswith("skip_"):
        # Пропуск анкеты
        skipped_user_id = int(data.split("_")[1])
        likes[user_id].add(skipped_user_id)  # Добавляем в просмотренные

        await query.edit_message_caption(
            caption="Анкета пропущена.",
            parse_mode='Markdown'
        )

        # Показываем следующую анкету
        await asyncio.sleep(1)
        await discover_profiles(update, context)

    elif data == "discovery_next":
        # Показать следующую анкету
        current_id = context.user_data.get('current_discovery_id')
        if current_id:
            likes[user_id].add(current_id)  # Добавляем текущую анкету в просмотренные

        await query.delete_message()
        await discover_profiles(update, context)

    elif data == "discovery_filter":
        # Перейти к фильтру по городу
        await query.delete_message()
        await search_city(update, context)


async def show_likes(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Показать полученные симпатии"""
    user_id = update.effective_user.id

    # Проверяем активный чат
    if user_id in active_chats:
        await show_active_chat(update, context)
        return

    if user_id not in user_profiles:
        await update.message.reply_text(
            "Сначала создайте анкету с помощью /start"
        )
        return

    # Находим пользователей, которые лайкнули текущего пользователя
    user_likers = []
    for liker_id, liked_users in likes.items():
        if user_id in liked_users and liker_id in user_profiles:
            user_likers.append(liker_id)

    if not user_likers:
        await update.message.reply_text(
            "У вас пока нет симпатий. Используйте /discover чтобы просматривать анкеты!"
        )
        return

    # Создаем клавиатуру с лайкнувшими пользователями
    keyboard = []
    for liker_id in user_likers:
        profile = user_profiles[liker_id]
        button_text = f"{profile['name']}, {profile['age']}, {profile['city']}"
        keyboard.append([InlineKeyboardButton(button_text, callback_data=f"view_like_{liker_id}")])

    reply_markup = InlineKeyboardMarkup(keyboard)

    await update.message.reply_text(
        f"❤️ *Вас оценили ({len(user_likers)})*:\n\n"
        "Выберите анкету для просмотра:",
        parse_mode='Markdown',
        reply_markup=reply_markup
    )


async def show_matches(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Показать взаимные симпатии"""
    user_id = update.effective_user.id

    # Проверяем активный чат
    if user_id in active_chats:
        await show_active_chat(update, context)
        return

    if user_id not in user_profiles:
        await update.message.reply_text(
            "Сначала создайте анкету с помощью /start"
        )
        return

    # Находим взаимные симпатии
    user_matches = []
    for (u1, u2), match_time in matches.items():
        if u1 == user_id:
            user_matches.append((u2, match_time))
        elif u2 == user_id:
            user_matches.append((u1, match_time))

    if not user_matches:
        await update.message.reply_text(
            "У вас пока нет взаимных симпатий. Продолжайте ставить лайки!"
        )
        return

    # Создаем клавиатуру с мэтчами
    keyboard = []
    for match_id, match_time in user_matches:
        if match_id in user_profiles:
            profile = user_profiles[match_id]
            button_text = f"{profile['name']}, {profile['age']} 💬"
            keyboard.append([InlineKeyboardButton(button_text, callback_data=f"chat_with_{match_id}")])

    reply_markup = InlineKeyboardMarkup(keyboard)

    await update.message.reply_text(
        f"💕 *Взаимные симпатии ({len(user_matches)})*:\n\n"
        "Выберите пользователя для общения:",
        parse_mode='Markdown',
        reply_markup=reply_markup
    )


