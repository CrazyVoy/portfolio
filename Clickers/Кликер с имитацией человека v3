@dataclass
class HumanBehaviorConfig:
    """Конфигурация человеческого поведения"""
    # Движения мыши
    mouse_human_movement: bool = True
    mouse_move_speed_variation: Tuple[float, float] = (0.1, 0.5)
    mouse_curve_movements: bool = True
    mouse_occasional_tremor: bool = True
    tremor_intensity: float = 0.5

    # Время реакции
    reaction_time_variation: Tuple[float, float] = (0.05, 0.3)
    thinking_before_action: bool = True
    min_thinking_time: float = 0.1
    max_thinking_time: float = 0.8

    # Паттерны кликов
    click_duration_variation: Tuple[float, float] = (0.01, 0.05)
    double_click_occasionally: bool = True
    double_click_chance: float = 0.05
    misclick_chance: float = 0.02
    misclick_offset_range: int = 15

    # Перерывы и отдых
    take_breaks: bool = True
    min_work_time: float = 30.0
    max_work_time: float = 300.0
    min_break_time: float = 5.0
    max_break_time: float = 60.0

    # Паттерны взгляда
    look_around_occasionally: bool = True
    look_around_chance: float = 0.1

    # Тайминг
    random_delays_between_actions: bool = True
    min_action_delay: float = 0.05
    max_action_delay: float = 0.3


@dataclass
class GameBotConfig:
    """Конфигурация бота для игры"""
    target_words: List[str] = field(default_factory=lambda: ["Создать", "Повторить", "Create", "Repeat"])
    confidence_threshold: float = 0.7
    scan_interval: float = 0.5
    stop_key: str = "f8"
    start_key: str = "f9"
    scan_region: Optional[Tuple[int, int, int, int]] = None
    click_delay: float = 0.3
    save_screenshots: bool = False
    debug_mode: bool = False
    human_behavior: HumanBehaviorConfig = field(default_factory=HumanBehaviorConfig)
    emulate_human: bool = True


class HumanEmulator:
    """Класс для эмуляции человеческого поведения"""

    def __init__(self, config: HumanBehaviorConfig):
        self.config = config
        self.personal_traits = self.generate_personal_traits()
        self.last_action_time = time.time()
        self.work_start_time = time.time()
        self.in_break = False
        self.click_pattern = []
        self.mouse_path = []
        self.screen_check_points = [
            (100, 100), (500, 300), (900, 200),
            (300, 600), (700, 400), (200, 200),
            (800, 600), (400, 400), (600, 100)
        ]

    def generate_personal_traits(self) -> dict:
        """Генерация уникальных черт поведения"""
        return {
            "dominant_hand": random.choice(["right", "left"]),
            "mouse_sensitivity": random.uniform(0.8, 1.2),
            "click_force": random.choice(["light", "medium", "firm"]),
            "movement_style": random.choice(["direct", "curvy", "hesitant"]),
            "focus_area": random.choice(["center", "left", "right", "top", "bottom"]),
            "idle_behavior": random.choice(["still", "small_moves", "circles"]),
        }

    def human_delay(self, base_time: float = 0) -> float:
        """Добавление человеческой задержки"""
        if base_time == 0:
            delay = random.uniform(*self.config.reaction_time_variation)
        else:
            variation = random.uniform(0.8, 1.2)
            delay = base_time * variation

        if self.config.thinking_before_action:
            thinking = random.uniform(
                self.config.min_thinking_time,
                self.config.max_thinking_time
            )
            delay += thinking

        return max(0.01, delay)

    def human_move_to(self, x: int, y: int, duration: float = None):
        """
        Движение мыши как человек (не прямая линия)
        """
        if not self.config.mouse_human_movement:
            pyautogui.moveTo(x, y, duration=0.1)
            return

        current_x, current_y = pyautogui.position()

        if duration is None:
            duration = random.uniform(*self.config.mouse_move_speed_variation)

        # Человеческое движение с кривой
        if self.config.mouse_curve_movements:
            self.curved_movement(current_x, current_y, x, y, duration)
        else:
            pyautogui.moveTo(x, y, duration=duration)

        # Случайная дрожь
        if self.config.mouse_occasional_tremor and random.random() < 0.1:
            self.mouse_tremor()

        # Запись пути
        self.mouse_path.append((x, y, time.time()))

    def curved_movement(self, start_x: int, start_y: int, end_x: int, end_y: int, duration: float):
        """Движение по кривой как человек"""
        steps = int(duration * 100)

        # Контрольная точка для кривой Безье
        control_x = (start_x + end_x) / 2 + random.uniform(-50, 50)
        control_y = (start_y + end_y) / 2 + random.uniform(-50, 50)

        for i in range(steps):
            t = i / steps

            # Кривая Безье
            x = (1 - t) ** 2 * start_x + 2 * (1 - t) * t * control_x + t ** 2 * end_x
            y = (1 - t) ** 2 * start_y + 2 * (1 - t) * t * control_y + t ** 2 * end_y

            # Случайные отклонения
            if random.random() < 0.3:
                x += random.uniform(-2, 2)
                y += random.uniform(-2, 2)

            pyautogui.moveTo(int(x), int(y))
            time.sleep(duration / steps)

    def mouse_tremor(self):
        """Легкая дрожь мыши как у человека"""
        intensity = self.config.tremor_intensity
        for _ in range(random.randint(2, 5)):
            dx = random.uniform(-intensity, intensity)
            dy = random.uniform(-intensity, intensity)
            x, y = pyautogui.position()
            pyautogui.moveTo(x + dx, y + dy, duration=0.01)
            time.sleep(0.01)

    def human_click(self, x: int = None, y: int = None, button: str = 'left'):
        """
        Человеческий клик с вариациями
        """
        # Иногда промахиваемся
        if random.random() < self.config.misclick_chance:
            offset_x = random.randint(-self.config.misclick_offset_range,
                                      self.config.misclick_offset_range)
            offset_y = random.randint(-self.config.misclick_offset_range,
                                      self.config.misclick_offset_range)
            if x is not None and y is not None:
                x += offset_x
                y += offset_y

        # Двигаемся к цели
        if x is not None and y is not None:
            self.human_move_to(x, y)

        # Задержка перед кликом
        time.sleep(self.human_delay(0.05))

        # Вариация длительности клика
        click_duration = random.uniform(*self.config.click_duration_variation)

        # Иногда двойной клик
        if self.config.double_click_occasionally and random.random() < self.config.double_click_chance:
            pyautogui.click(button=button, clicks=2, interval=0.1)
        else:
            pyautogui.mouseDown(button=button)
            time.sleep(click_duration)
            pyautogui.mouseUp(button=button)

        # Запись паттерна
        self.click_pattern.append({
            'time': time.time(),
            'position': pyautogui.position(),
            'duration': click_duration,
        })

        # Случайная пауза после клика
        if self.config.random_delays_between_actions:
            time.sleep(random.uniform(self.config.min_action_delay,
                                      self.config.max_action_delay))

    def look_around(self):
        """Человек смотрит по сторонам"""
        if not self.config.look_around_occasionally:
            return

        if random.random() < self.config.look_around_chance:
            point = random.choice(self.screen_check_points)
            self.human_move_to(point[0], point[1])
            time.sleep(random.uniform(0.2, 0.8))

            if self.mouse_path:
                last_pos = self.mouse_path[-1]
                self.human_move_to(last_pos[0], last_pos[1])

    def take_break(self):
        """Человек делает перерыв"""
        if not self.config.take_breaks or self.in_break:
            return

        work_time = time.time() - self.work_start_time
        if work_time > random.uniform(self.config.min_work_time,
                                      self.config.max_work_time):

            self.in_break = True
            break_duration = random.uniform(self.config.min_break_time,
                                            self.config.max_break_time)

            print(f"[Человек] Делаю перерыв на {break_duration:.1f} сек...")

            # Случайная активность на перерыве
            activity = random.choice(["move_mouse_randomly", "scroll", "alt_tab", "small_pause"])

            if activity == "move_mouse_randomly":
                self.random_mouse_movement(break_duration)
            elif activity == "scroll":
                self.random_scroll(break_duration)
            elif activity == "alt_tab":
                self.alt_tab_activity()
            elif activity == "small_pause":
                time.sleep(break_duration)

            print(f"[Человек] Перерыв окончен")
            self.in_break = False
            self.work_start_time = time.time()

    def random_mouse_movement(self, duration: float):
        """Случайные движения мыши"""
        end_time = time.time() + duration
        screen_width, screen_height = pyautogui.size()

        while time.time() < end_time:
            x = random.randint(100, screen_width - 100)
            y = random.randint(100, screen_height - 100)

            move_duration = random.uniform(0.5, 2.0)
            self.human_move_to(x, y, move_duration)

            if random.random() < 0.3:
                time.sleep(random.uniform(0.5, 2.0))

    def random_scroll(self, duration: float):
        """Случайный скроллинг"""
        end_time = time.time() + duration
        scroll_amounts = [1, 2, 3, -1, -2, -3]

        while time.time() < end_time:
            amount = random.choice(scroll_amounts)
            pyautogui.scroll(amount)
            time.sleep(random.uniform(0.2, 1.0))

    def alt_tab_activity(self):
        """Имитация переключения между окнами"""
        pyautogui.hotkey('alt', 'tab')
        time.sleep(random.uniform(0.5, 2.0))

        if random.random() < 0.5:
            pyautogui.hotkey('alt', 'shift', 'tab')
            time.sleep(random.uniform(0.5, 1.0))

    def adjust_for_personal_traits(self, x: int, y: int) -> Tuple[int, int]:
        """Корректировка позиции под личные привычки"""
        if self.personal_traits["dominant_hand"] == "left":
            x += random.randint(-10, -5)

        if self.personal_traits["focus_area"] == "center":
            screen_width, screen_height = pyautogui.size()
            center_x, center_y = screen_width // 2, screen_height // 2
            dx = center_x - x
            dy = center_y - y
            x += int(dx * 0.1)

        return x, y

    def get_behavior_stats(self) -> dict:
        """Статистика поведения"""
        return {
            "personal_traits": self.personal_traits,
            "total_clicks": len(self.click_pattern),
            "mouse_path_length": len(self.mouse_path),
            "work_time": time.time() - self.work_start_time
        }


class GameTextClickerBot:
    def __init__(self, config: Optional[GameBotConfig] = None):
        """
        Бот для поиска и клика по тексту в игре

        :param config: конфигурация бота
        """
        self.config = config or GameBotConfig()

        self.running = False
        self.paused = False
        self.scan_thread = None
        self.click_count = 0
        self.found_positions = {}

        # Инициализация эмулятора человека
        self.human_emulator = HumanEmulator(self.config.human_behavior)

        # Статистика
        self.session_start = None
        self.behavior_log = []

        # Проверяем наличие tesseract
        self.check_ocr_availability()

    def check_ocr_availability(self):
        """Проверка доступности OCR"""
        try:
            pytesseract.get_tesseract_version()
            print("✓ Tesseract OCR доступен")
            return True
        except:
            print("✗ Tesseract OCR не найден!")
            print("Установите Tesseract OCR:")
            print("Windows: https://github.com/UB-Mannheim/tesseract/wiki")
            print("Linux: sudo apt-get install tesseract-ocr")
            print("Mac: brew install tesseract")
            print("\nТакже установите языковые данные для русского:")
            print("rus.traineddata в папку tessdata")
            return False

    def capture_screen(self, region: Optional[Tuple] = None) -> Image:
        """
        Захват экрана или области

        :param region: область (x1, y1, x2, y2)
        :return: изображение PIL
        """
        if region:
            screenshot = ImageGrab.grab(bbox=region)
        else:
            screenshot = ImageGrab.grab()

        return screenshot

    def preprocess_image(self, image: Image) -> np.ndarray:
        """
        Предобработка изображения для улучшения распознавания

        :param image: изображение PIL
        :return: обработанное изображение OpenCV
        """
        # Конвертируем PIL в OpenCV
        img_cv = cv2.cvtColor(np.array(image), cv2.COLOR_RGB2BGR)

        # Увеличиваем контраст
        lab = cv2.cvtColor(img_cv, cv2.COLOR_BGR2LAB)
        l, a, b = cv2.split(lab)
        clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8, 8))
        cl = clahe.apply(l)
        limg = cv2.merge((cl, a, b))
        enhanced = cv2.cvtColor(limg, cv2.COLOR_LAB2BGR)

        # Конвертируем в grayscale
        gray = cv2.cvtColor(enhanced, cv2.COLOR_BGR2GRAY)

        # Бинаризация
        _, thresh = cv2.threshold(gray, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)

        # Удаление шума
        kernel = np.ones((2, 2), np.uint8)
        processed = cv2.morphologyEx(thresh, cv2.MORPH_CLOSE, kernel)

        return processed

    def find_text_positions(self, image: Image, target_words: List[str]) -> List[dict]:
        """
        Поиск позиций текста на изображении

        :param image: изображение PIL
        :param target_words: список искомых слов
        :return: список найденных позиций
        """
        positions = []

        try:
            # Используем Tesseract для распознавания текста с указанием языка
            custom_config = r'--oem 3 --psm 6 -l rus+eng'
            data = pytesseract.image_to_data(image, config=custom_config, output_type=pytesseract.Output.DICT)

            if self.config.debug_mode:
                print(f"Распознано {len(data['text'])} текстовых элементов")

            # Обрабатываем каждый распознанный текст
            for i in range(len(data['text'])):
                text = data['text'][i].strip()
                conf = float(data['conf'][i]) / 100  # Конвертируем проценты в 0-1

                if text and conf >= self.config.confidence_threshold:
                    # Ищем целевые слова (регистронезависимо)
                    for target in target_words:
                        if target.lower() in text.lower():
                            # Получаем координаты
                            x = data['left'][i]
                            y = data['top'][i]
                            w = data['width'][i]
                            h = data['height'][i]

                            # Центр текста
                            center_x = x + w // 2
                            center_y = y + h // 2

                            positions.append({
                                'text': text,
                                'target': target,
                                'confidence': conf,
                                'x': center_x,
                                'y': center_y,
                                'bbox': (x, y, x + w, y + h),
                                'screen_region': self.config.scan_region
                            })

                            if self.config.debug_mode:
                                print(f"Найдено: '{text}' -> '{target}' "
                                      f"(conf: {conf:.2f}) at ({center_x}, {center_y})")
                            break

        except Exception as e:
            print(f"Ошибка при распознавании текста: {e}")

        return positions

    def template_matching_fallback(self, screenshot: np.ndarray) -> List[dict]:
        """
        Резервный метод: поиск по шаблону (если OCR не работает)

        :param screenshot: скриншот OpenCV
        :return: список позиций
        """
        positions = []

        # Создаем простые шаблоны для слов (в реальности нужны реальные изображения)
        # Здесь можно добавить загрузку сохраненных шаблонов
        templates = {
            "Создать": self.create_text_template("Создать"),
            "Повторить": self.create_text_template("Повторить")
        }

        for word, template in templates.items():
            if template is not None:
                result = cv2.matchTemplate(screenshot, template, cv2.TM_CCOEFF_NORMED)
                locations = np.where(result >= self.config.confidence_threshold)

                for pt in zip(*locations[::-1]):
                    x, y = pt[0] + template.shape[1] // 2, pt[1] + template.shape[0] // 2
                    positions.append({
                        'text': word,
                        'target': word,
                        'confidence': result[pt[1], pt[0]],
                        'x': x,
                        'y': y,
                        'bbox': (pt[0], pt[1], pt[0] + template.shape[1], pt[1] + template.shape[0]),
                        'method': 'template'
                    })

        return positions

    def create_text_template(self, text: str) -> Optional[np.ndarray]:
        """
        Создание шаблона текста (для резервного метода)

        :param text: текст для шаблона
        :return: изображение шаблона
        """
        try:
            # Создаем изображение с текстом
            from PIL import Image, ImageDraw, ImageFont

            font = ImageFont.load_default()
            bbox = font.getbbox(text)
            width, height = bbox[2] - bbox[0], bbox[3] - bbox[1]

            img = Image.new('RGB', (width + 20, height + 20), color='white')
            draw = ImageDraw.Draw(img)
            draw.text((10, 10), text, font=font, fill='black')

            # Конвертируем в OpenCV
            template = cv2.cvtColor(np.array(img), cv2.COLOR_RGB2BGR)
            template_gray = cv2.cvtColor(template, cv2.COLOR_BGR2GRAY)

            return template_gray
        except:
            return None

    def scan_and_click(self):
        """Основной цикл сканирования и кликов с эмуляцией человека"""
        print("Начинаю сканирование экрана с эмуляцией человека...")
        print(f"Ищем слова: {', '.join(self.config.target_words)}")
        print(f"[Человек] Мои черты: {self.human_emulator.personal_traits}")

        last_click_time = 0
        click_cooldown = 1.0  # Задержка между кликами в секундах
        last_scan_time = 0
        scan_interval = self.config.scan_interval

        while self.running:
            if self.paused:
                time.sleep(0.1)
                continue

            # Проверяем на перерыв
            self.human_emulator.take_break()

            # Человек смотрит по сторонам
            self.human_emulator.look_around()

            try:
                # Сканирование с человеческим интервалом
                current_time = time.time()
                if current_time - last_scan_time >= scan_interval:

                    # Захватываем экран
                    screenshot_pil = self.capture_screen(self.config.scan_region)

                    # Сохраняем скриншоты если нужно
                    if self.config.save_screenshots and self.click_count % 10 == 0:
                        screenshot_pil.save(f"screenshot_{self.click_count}.png")

                    # Предобработка для OCR
                    processed_img = self.preprocess_image(screenshot_pil)

                    # Конвертируем обратно в PIL для tesseract
                    processed_pil = Image.fromarray(processed_img)

                    # Ищем текст
                    positions = self.find_text_positions(processed_pil, self.config.target_words)

                    # Если не нашли через OCR, пробуем шаблонный поиск
                    if not positions:
                        screenshot_cv = cv2.cvtColor(np.array(screenshot_pil), cv2.COLOR_RGB2BGR)
                        positions = self.template_matching_fallback(screenshot_cv)

                    # Кликаем по найденным позициям с человеческим поведением
                    for pos in positions:
                        # Проверяем кулдаун
                        if current_time - last_click_time >= click_cooldown:

                            # Корректируем координаты если сканировали регион
                            if self.config.scan_region:
                                x = pos['x'] + (self.config.scan_region[0] if self.config.scan_region else 0)
                                y = pos['y'] + (self.config.scan_region[1] if self.config.scan_region else 0)
                            else:
                                x, y = pos['x'], pos['y']

                            # Корректируем под личные привычки
                            if self.config.emulate_human:
                                x, y = self.human_emulator.adjust_for_personal_traits(x, y)

                            print(f"Кликаю по '{pos['text']}' ({pos['target']}) "
                                  f"в позиции ({x}, {y}) conf: {pos['confidence']:.2f}")

                            # Человеческий клик
                            if self.config.emulate_human:
                                self.human_emulator.human_click(x, y)
                            else:
                                pyautogui.moveTo(x, y, duration=0.1)
                                time.sleep(0.05)
                                pyautogui.click()

                            self.click_count += 1
                            last_click_time = current_time

                            # Статистика
                            if pos['target'] not in self.found_positions:
                                self.found_positions[pos['target']] = 0
                            self.found_positions[pos['target']] += 1

                            # Логирование
                            self.behavior_log.append({
                                'time': datetime.now().isoformat(),
                                'action': 'click',
                                'position': (x, y),
                                'target': pos['text'],
                                'confidence': pos['confidence']
                            })

                            # Небольшая задержка после клика
                            time.sleep(self.config.click_delay)

                            # Вариация интервала сканирования
                            scan_interval = random.uniform(
                                self.config.scan_interval * 0.5,
                                self.config.scan_interval * 1.5
                            )
                            break  # Кликаем только по первому найденному

                    last_scan_time = current_time

                # Выводим статистику
                if self.click_count > 0 and self.click_count % 5 == 0:
                    print(f"Всего кликов: {self.click_count}")

                    # Показываем человеческую статистику
                    human_stats = self.human_emulator.get_behavior_stats()
                    print(f"[Человек] Стиль: {human_stats['personal_traits']['movement_style']}, "
                          f"Рука: {human_stats['personal_traits']['dominant_hand']}")

                # Человеческая задержка между проверками
                if self.config.emulate_human:
                    time.sleep(random.uniform(0.05, 0.2))
                else:
                    time.sleep(0.1)

            except Exception as e:
                print(f"Ошибка в цикле сканирования: {e}")
                time.sleep(1)

    def calibrate_region(self):
        """Калибровка области сканирования"""
        print("\n=== КАЛИБРАЦИЯ ОБЛАСТИ СКАНИРОВАНИЯ ===")
        print("1. Наведите курсор на ВЕРХНИЙ ЛЕВЫЙ угол области")
        print("   и нажмите Enter")
        input()
        x1, y1 = pyautogui.position()

        print("2. Наведите курсор на НИЖНИЙ ПРАВЫЙ угол области")
        print("   и нажмите Enter")
        input()
        x2, y2 = pyautogui.position()

        self.config.scan_region = (min(x1, x2), min(y1, y2), max(x1, x2), max(y1, y2))
        print(f"\nОбласть сканирования установлена: {self.config.scan_region}")
        print(f"Размер: {x2 - x1}x{y2 - y1} пикселей")

        # Тестовый захват области
        test_img = self.capture_screen(self.config.scan_region)
        test_img.save("calibration_test.png")
        print("Тестовый скриншот сохранен: calibration_test.png")

        return self.config.scan_region

    def test_ocr_in_region(self):
        """Тест OCR в выбранной области"""
        if not self.config.scan_region:
            print("Сначала выполните калибровку области!")
            return

        print("\n=== ТЕСТ OCR ===")
        screenshot = self.capture_screen(self.config.scan_region)
        processed = self.preprocess_image(screenshot)
        test_img = Image.fromarray(processed)

        # Показываем что видит OCR
        custom_config = r'--oem 3 --psm 6 -l rus+eng'
        text = pytesseract.image_to_string(test_img, config=custom_config)

        print("Распознанный текст в области:")
        print("-" * 40)
        print(text)
        print("-" * 40)

        # Сохраняем обработанное изображение
        test_img.save("ocr_test_processed.png")
        screenshot.save("ocr_test_original.png")
        print("Изображения сохранены для проверки")

    def test_human_behavior(self):
        """Тест эмуляции человеческого поведения"""
        print("\n=== ТЕСТ ЭМУЛЯЦИИ ЧЕЛОВЕКА ===")
        print("Демонстрация человеческих движений мыши")

        screen_width, screen_height = pyautogui.size()
        points = [
            (screen_width // 4, screen_height // 4),
            (screen_width * 3 // 4, screen_height // 4),
            (screen_width * 3 // 4, screen_height * 3 // 4),
            (screen_width // 4, screen_height * 3 // 4),
        ]

        for i, point in enumerate(points, 1):
            print(f"Движение {i}/4 к {point}")
            self.human_emulator.human_move_to(*point)
            time.sleep(0.5)

            if random.random() < 0.3:
                self.human_emulator.human_click()
                time.sleep(0.3)

        print("\nТест завершен! Черты персонажа:")
        for key, value in self.human_emulator.personal_traits.items():
            print(f"  {key}: {value}")

    def start(self):
        """Запуск бота"""
        if self.running:
            print("Бот уже запущен!")
            return

        self.running = True
        self.session_start = time.time()
        self.scan_thread = threading.Thread(target=self.scan_and_click, daemon=True)
        self.scan_thread.start()

        print(f"\nБот запущен! Ищем: {', '.join(self.config.target_words)}")
        print(f"Область сканирования: {self.config.scan_region or 'Весь экран'}")
        print(f"Эмуляция человека: {'ВКЛ' if self.config.emulate_human else 'ВЫКЛ'}")
        print(f"Для остановки нажмите: {self.config.stop_key}")
        print(f"Для паузы/возобновления нажмите: {self.config.start_key}")
        print(f"Черты персонажа: {self.human_emulator.personal_traits}")

        # Регистрируем горячие клавиши
        keyboard.add_hotkey(self.config.stop_key, self.stop)
        keyboard.add_hotkey(self.config.start_key, self.toggle_pause)

        # Ждем остановки
        try:
            while self.running:
                # Периодический вывод статистики
                if self.click_count > 0 and self.click_count % 20 == 0:
                    self.show_stats()
                time.sleep(1)
        except KeyboardInterrupt:
            self.stop()

    def toggle_pause(self):
        """Переключение паузы"""
        self.paused = not self.paused
        status = "приостановлен" if self.paused else "возобновлен"
        print(f"Бот {status}")

        # Человек отдыхает на паузе
        if self.paused and self.config.emulate_human:
            self.human_emulator.random_mouse_movement(2.0)

    def show_stats(self):
        """Показать статистику"""
        if self.session_start:
            elapsed = time.time() - self.session_start
            cpm = self.click_count / (elapsed / 60) if elapsed > 0 else 0

            print(f"\n[Статистика] Кликов: {self.click_count}, "
                  f"Время: {elapsed:.1f}с, CPM: {cpm:.1f}")

            human_stats = self.human_emulator.get_behavior_stats()
            print(f"[Человек] Паттерн: {human_stats['personal_traits']['movement_style']}, "
                  f"Рука: {human_stats['personal_traits']['dominant_hand']}")

    def stop(self):
        """Остановка бота"""
        if not self.running:
            return

        self.running = False
        self.paused = False

        if self.scan_thread and self.scan_thread.is_alive():
            self.scan_thread.join(timeout=1)

        print(f"\n" + "=" * 60)
        print("БОТ ОСТАНОВЛЕН")
        print("=" * 60)
        print(f"Всего кликов: {self.click_count}")

        if self.session_start:
            elapsed = time.time() - self.session_start
            print(f"Время работы: {elapsed:.1f} секунд")
            print(f"Средняя скорость: {self.click_count / (elapsed / 60):.1f} CPM")

        print("\nСтатистика по найденным словам:")
        for word, count in self.found_positions.items():
            print(f"  {word}: {count} раз")

        if self.config.emulate_human:
            print("\nПОВЕДЕНЧЕСКИЕ ДАННЫЕ:")
            human_stats = self.human_emulator.get_behavior_stats()
            print(f"Стиль движения: {human_stats['personal_traits']['movement_style']}")
            print(f"Ведущая рука: {human_stats['personal_traits']['dominant_hand']}")
            print(f"Чувствительность мыши: {human_stats['personal_traits']['mouse_sensitivity']:.2f}")
        print("=" * 60)


