                card.className = `companion-card ${isHired ? 'hired' : canHire ? 'available' : ''}`;
                
                card.innerHTML = `
                    <div class="companion-image">
                        <img src="${companion.image}" alt="${companion.name}" onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>👥</text></svg>'">
                    </div>
                    <div style="color: #ffd700; font-weight: bold;">${companion.name}</div>
                    <div style="color: #ffd700; font-weight: bold; margin: 10px 0;">${companion.price} золота</div>
                    <div style="font-size: 0.9rem; color: #a3d9ff; margin: 5px 0;">
                        ⚔️ ${companion.attack} 🛡️ ${companion.defense} ❤️ ${companion.health}
                    </div>
                    <div style="font-size: 0.8rem; color: #2ecc71; margin: 5px 0;">
                        ${companion.description}
                    </div>
                    <div style="font-size: 0.8rem; color: #ffd700; margin: 5px 0;">
                        Способность: ${companion.ability}
                    </div>
                    ${isHired ? 
                        '<div style="color: #ffd700; font-weight: bold; margin-top: 10px;">Уже нанят</div>' :
                        `<button class="companion-hire-btn" ${canHire ? '' : 'disabled'}>
                            ${canHire ? 'Нанять' : 'Мест нет'}
                        </button>`
                    }
