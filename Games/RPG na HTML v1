            actionsGrid.appendChild(tavernContent);
            
            const exitBtn = document.createElement("button");
            exitBtn.className = "action-btn";
            exitBtn.textContent = "🏠 Выйти из таверны";
            exitBtn.onclick = () => goToLocation("village");
            actionsGrid.appendChild(exitBtn);
        }

        function hireCompanion(companion) {
            if (player.gold < companion.price) {
                updateLog(`Недостаточно золота! Нужно ${companion.price} золота.`, "system");
                showNotification(`Недостаточно золота для найма ${companion.name}!`);
                return;
            }
            
            if (player.companions.length >= player.maxCompanions) {
                updateLog("У вас максимальное количество спутников!", "system");
                showNotification("Нельзя нанять больше спутников!");
                return;
            }
            
            player.gold -= companion.price;
            const hiredCompanion = {
                ...JSON.parse(JSON.stringify(companion)),
                currentHealth: companion.health,
                uniqueId: Date.now() + Math.random()
            };
            player.companions.push(hiredCompanion);
            
            updatePlayerStats();
            updateCompanionsDisplay();
            updateLog(`Вы наняли ${companion.name} за ${companion.price} золота!`, "equip");
            showNotification(`Спутник ${companion.name} присоединился к вам!`);
            
            showTavernCompanions();
            saveGame();
        }

        function updateCompanionsDisplay() {
            const container = document.getElementById("companions-container");
            container.innerHTML = "";
            
            player.companions.forEach(companion => {
                const element = document.createElement("div");
                element.className = "inventory-item";
                element.innerHTML = `
                    <div style="font-size: 1.5rem; margin-bottom: 5px;">
                        ${companion.type === 'archer' ? '🏹' : 
                          companion.type === 'warrior' ? '⚔️' : 
                          companion.type === 'mage' ? '🧙' : '👥'}
                    </div>
                    <div style="font-weight: bold;">${companion.name}</div>
                    <div style="font-size: 0.8rem; color: #a3d9ff;">
                        ❤️ ${companion.currentHealth}/${companion.health}
                    </div>
                `;
                
                element.onclick = () => {
                    updateLog(`${companion.name}: ${companion.description}`, "system");
                    showNotification(`${companion.name}: ${companion.ability}`);
                };
                
                container.appendChild(element);
            });
            
            const emptySlots = player.maxCompanions - player.companions.length;
            for (let i = 0; i < emptySlots; i++) {
                const emptyElement = document.createElement("div");
                emptyElement.className = "inventory-item";
                emptyElement.innerHTML = `<div style="color: #666;">Пустой слот</div>`;
                container.appendChild(emptyElement);
            }
        }

        function drinkAle() {
            if (player.gold < 10) {
                updateLog("Недостаточно золота для эля!", "system");
                showNotification("Недостаточно золота для эля!");
                return;
            }
            
            player.gold -= 10;
            player.health = Math.min(player.maxHealth, player.health + 10);
            updatePlayerStats();
            updateHealthBars();
            updateLog("Вы выпили эль и восстановили 10 здоровья", "heal");
            showNotification("Выпит эль! +10 здоровья, -10 золота");
