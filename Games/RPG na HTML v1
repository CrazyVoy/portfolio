        // ============ БОЕВАЯ СИСТЕМА ============
        function startCombatInLocation() {
            // Вероятности для массовых боев
            const rand = Math.random();
            let enemyCount = 1;
            if (rand <= 0.5) enemyCount = 1;      // 50%
            else if (rand <= 0.75) enemyCount = 2; // 25%
            else if (rand <= 0.875) enemyCount = 3; // 12.5%
            else if (rand <= 0.9375) enemyCount = 4; // 6.25%
            else enemyCount = 5;                   // 6.25%

            if (enemyCount > 1) {
                startMassCombat(enemyCount);
            } else {
                startSingleCombat();
            }
        }

        function startSingleCombat() {
            let possibleEnemies = [];
            for (const enemyType in ENEMIES) {
                if (ENEMIES[enemyType].location.includes(player.location)) {
                    possibleEnemies.push(enemyType);
                }
            }
            
            if (possibleEnemies.length === 0) {
                possibleEnemies = ["goblin", "wolf"];
            }
            
            const enemyType = possibleEnemies[Math.floor(Math.random() * possibleEnemies.length)];
            enemy = JSON.parse(JSON.stringify(ENEMIES[enemyType]));
            
            inCombat = true;
            isPlayerTurn = true;
            playerBerserkMode = false;
            playerDefensiveMode = false;
            
            document.getElementById("mass-combat-container").style.display = "none";
            updateLocation();
            updateHealthBars();
            
            updateLog(`Вы встретили ${enemy.name}! Начинается бой!`, "combat");
            showNotification(`Встречен ${enemy.name}! Начинается бой!`);
        }

        function startMassCombat(count) {
            enemiesInCombat = [];
            let possibleEnemies = [];
            
            for (const enemyType in ENEMIES) {
                if (ENEMIES[enemyType].location.includes(player.location)) {
                    possibleEnemies.push(enemyType);
                }
            }
            
            if (possibleEnemies.length === 0) {
                possibleEnemies = ["goblin", "wolf"];
            }
            
            for (let i = 0; i < count; i++) {
                const enemyType = possibleEnemies[Math.floor(Math.random() * possibleEnemies.length)];
                const enemyCopy = JSON.parse(JSON.stringify(ENEMIES[enemyType]));
                enemyCopy.uniqueId = Date.now() + i;
                enemiesInCombat.push(enemyCopy);
            }
            
            companionsInCombat = player.companions.map(c => ({
                ...JSON.parse(JSON.stringify(c)),
                isActive: true
            }));
            
            inCombat = true;
            isPlayerTurn = true;
            currentEnemyIndex = 0;
            playerBerserkMode = false;
            playerDefensiveMode = false;
            
            document.getElementById("mass-combat-container").style.display = "block";
            updateMassCombatDisplay();
            updateLocation();
            
            updateLog(`Вы встретили группу из ${count} врагов!`, "combat");
            showNotification(`Массовый бой с ${count} врагами!`);
        }

        function updateMassCombatDisplay() {
            const container = document.getElementById("enemies-container");
            container.innerHTML = "";
            
            enemiesInCombat.forEach((enemy, index) => {
                if (enemy.health <= 0) return;
                
                const element = document.createElement("div");
                element.className = `enemy-mini ${index === currentEnemyIndex ? 'active' : ''} ${enemy.health <= 0 ? 'defeated' : ''}`;
                element.innerHTML = `
                    <div class="enemy-mini-image">
                        <img src="${enemy.image}" alt="${enemy.name}" onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>${enemy.fallback}</text></svg>'">
                    </div>
                    <div style="font-size: 0.9rem; color: #ff9999; margin-bottom: 3px;">${enemy.name}</div>
                    <div style="font-size: 0.8rem; color: #fff;">${enemy.health}/${enemy.maxHealth}</div>
                    <div style="height: 5px; background: rgba(0,0,0,0.5); border-radius: 3px; margin-top: 3px; overflow: hidden;">
                        <div style="height: 100%; background: linear-gradient(90deg, #9b59b6, #8e44ad); width: ${(enemy.health / enemy.maxHealth) * 100}%"></div>
                    </div>
                `;
                
                element.onclick = () => {
                    if (isPlayerTurn && inCombat) {
                        currentEnemyIndex = index;
                        updateMassCombatDisplay();
                    }
                };
                
                container.appendChild(element);
            });
        }

        function playerAttack() {
            if (!inCombat || !enemy || !isPlayerTurn) return;
            performPlayerAttack(1.0, 1.0, "обычную");
        }

        function playerBerserkAttack() {
            if (!inCombat || !enemy || !isPlayerTurn) return;
            playerBerserkMode = true;
            updateLog("Вы впадаете в БЕРСЕРК! +50% урон, +50% получаемый урон", "berserk");
            performPlayerAttack(1.5, 1.5, "берсерка");
        }

        function playerDefensiveAttack() {
            if (!inCombat || !enemy || !isPlayerTurn) return;
            playerDefensiveMode = true;
            updateLog("Оборонительная стойка! -50% урон, -50% получаемый урон", "system");
            performPlayerAttack(0.5, 0.5, "оборонительный");
        }

        function performPlayerAttack(damageMultiplier, defenseMultiplier, attackType) {
            const stats = calculateStats();
            const critChance = player.critChance + stats.luck * 0.5;
            const isCritical = Math.random() * 100 < critChance;
            
            let baseDamage = stats.attack;
            const luckBonus = Math.floor(Math.random() * stats.luck);
            baseDamage += luckBonus;
            
            baseDamage = Math.floor(baseDamage * damageMultiplier);
            
            let finalDamage = baseDamage;
            if (isCritical) {
                finalDamage = Math.floor(baseDamage * player.critMultiplier);
            }
            
            finalDamage = Math.max(1, finalDamage - enemy.defense);
            enemy.health -= finalDamage;
            
            if (isCritical) {
                updateLog(`КРИТИЧЕСКИЙ УДАР! ${finalDamage} урона (${attackType} удар)!`, "critical");
                showNotification(`Критический удар! ${finalDamage} урона!`);
            } else {
                updateLog(`${finalDamage} урона (${attackType} удар)!`, "combat");
            }
            
            if (enemy.health <= 0) {
                enemy.health = 0;
                defeatEnemy();
            } else {
                isPlayerTurn = false;
                setTimeout(() => enemyTurn(defenseMultiplier), 800);
            }
            
            updateHealthBars();
            updatePlayerStats();
        }

        function massCombatAttack() {
            if (!inCombat || !isPlayerTurn || enemiesInCombat.length === 0) return;
            
            const currentEnemy = enemiesInCombat[currentEnemyIndex];
            if (!currentEnemy || currentEnemy.health <= 0) {
                const nextIndex = enemiesInCombat.findIndex((e, i) => i > currentEnemyIndex && e.health > 0);
                currentEnemyIndex = nextIndex !== -1 ? nextIndex : enemiesInCombat.findIndex(e => e.health > 0);
            }
            
            const targetEnemy = enemiesInCombat[currentEnemyIndex];
            if (!targetEnemy || targetEnemy.health <= 0) {
                updateLog("Этот враг уже повержен!", "system");
                updateMassCombatDisplay();
                return;
            }
            
            const stats = calculateStats();
            let baseDamage = stats.attack;
            const luckBonus = Math.floor(Math.random() * stats.luck);
            baseDamage += luckBonus;
            
            let finalDamage = Math.max(1, baseDamage - targetEnemy.defense);
            targetEnemy.health -= finalDamage;
            
            updateLog(`Вы нанесли ${finalDamage} урона ${targetEnemy.name}!`, "combat");
            
            // Атаки спутников
            companionsInCombat.forEach(companion => {
                if (companion.isActive && companion.currentHealth > 0) {
                    const companionDamage = Math.floor(companion.attack * (0.5 + Math.random() * 0.5));
                    targetEnemy.health -= companionDamage;
                    updateLog(`${companion.name} наносит ${companionDamage} урона!`, "combat");
                }
            });
            
            if (targetEnemy.health <= 0) {
                targetEnemy.health = 0;
                player.gold += targetEnemy.gold;
                player.exp += targetEnemy.exp;
                
                // Обновляем квесты
                checkEnemyForQuest(targetEnemy);
                
                updateLog(`${targetEnemy.name} повержен! +${targetEnemy.gold} золота, +${targetEnemy.exp} опыта`, "combat");
                
                const aliveEnemies = enemiesInCombat.filter(e => e.health > 0);
                if (aliveEnemies.length === 0) {
                    victoryMassCombat();
                    return;
                }
            }
            
            updateMassCombatDisplay();
            updatePlayerStats();
            
            isPlayerTurn = false;
            setTimeout(() => massCombatEnemyTurn(), 1000);
        }

        function massCombatBerserk() {
            if (!inCombat || !isPlayerTurn) return;
            
            updateLog("Мощная атака по всем врагам!", "berserk");
            showNotification("Мощная атака по всем врагам!");
            
            const stats = calculateStats();
            const baseDamage = Math.floor(stats.attack * 0.7);
            
            enemiesInCombat.forEach(enemy => {
                if (enemy.health > 0) {
                    let damage = Math.max(1, baseDamage - enemy.defense);
                    enemy.health -= damage;
                    updateLog(`${damage} урона ${enemy.name}!`, "combat");
                    
                    if (enemy.health <= 0) {
                        enemy.health = 0;
                        player.gold += enemy.gold;
                        player.exp += enemy.exp;
                        checkEnemyForQuest(enemy);
                    }
                }
            });
            
            player.health -= Math.floor(player.maxHealth * 0.1);
            updateLog("Ярость ранит и вас! -10% HP", "berserk");
            
            const aliveEnemies = enemiesInCombat.filter(e => e.health > 0);
            if (aliveEnemies.length === 0) {
                victoryMassCombat();
                return;
            }
            
            updateMassCombatDisplay();
            updateHealthBars();
            updatePlayerStats();
            
            isPlayerTurn = false;
            setTimeout(() => massCombatEnemyTurn(), 1000);
        }

        function enemyTurn(defenseMultiplier = 1.0) {
            if (!inCombat || !enemy) return;
            
            const isEnemyCritical = Math.random() * 100 < enemy.critChance;
            let enemyDamage = enemy.attack;
            
            if (isEnemyCritical) {
                enemyDamage = Math.floor(enemyDamage * 1.5);
            }
            
            enemyDamage = Math.floor(enemyDamage * defenseMultiplier);
            
            const stats = calculateStats();
            const dodgeChance = player.dodgeChance + stats.luck * 0.8;
            const isDodged = Math.random() * 100 < dodgeChance;
            
            if (isDodged) {
                updateLog(`Вы УВЕРНУЛИСЬ от атаки ${enemy.name}!`, "dodge");
                showNotification(`Вы увернулись от атаки ${enemy.name}!`);
            } else {
                const blockChance = player.blockChance + stats.defense * 0.3;
                const isBlocked = Math.random() * 100 < blockChance;
                
                if (isBlocked) {
                    enemyDamage = Math.floor(enemyDamage * 0.5);
                    player.health -= enemyDamage;
                    updateLog(`Вы БЛОКИРОВАЛИ атаку и получили ${enemyDamage} урона!`, "block");
                    showNotification(`Блокировано! Получено ${enemyDamage} урона.`);
                } else {
                    player.health -= enemyDamage;
                    
                    if (isEnemyCritical) {
                        updateLog(`КРИТИЧЕСКИЙ УДАР! ${enemy.name} наносит ${enemyDamage} урона!`, "critical");
                        showNotification(`Критический удар врага! Получено ${enemyDamage} урона!`);
                    } else {
                        updateLog(`${enemy.name} наносит ${enemyDamage} урона!`, "combat");
                    }
                }
            }
            
            if (player.health <= 0) {
                player.health = 0;
                gameOver();
                return;
            }
            
            playerBerserkMode = false;
            playerDefensiveMode = false;
            
            updateHealthBars();
            updatePlayerStats();
            
            isPlayerTurn = true;
            updateLog("Ваш ход. Выберите действие.", "system");
        }

        function massCombatEnemyTurn(defenseMultiplier = 1.0) {
            if (!inCombat) return;
            
            enemiesInCombat.forEach(enemy => {
                if (enemy.health > 0) {
                    const isEnemyCritical = Math.random() * 100 < enemy.critChance;
                    let enemyDamage = enemy.attack;
                    
                    if (isEnemyCritical) {
                        enemyDamage = Math.floor(enemyDamage * 1.5);
                    }
                    
                    enemyDamage = Math.floor(enemyDamage * defenseMultiplier);
                    
                    const stats = calculateStats();
                    const dodgeChance = player.dodgeChance + stats.luck * 0.8;
                    const isDodged = Math.random() * 100 < dodgeChance;
                    
                    if (isDodged) {
                        updateLog(`Вы УВЕРНУЛИСЬ от атаки ${enemy.name}!`, "dodge");
                    } else {
                        const blockChance = player.blockChance + stats.defense * 0.3;
                        const isBlocked = Math.random() * 100 < blockChance;
                        
                        if (isBlocked) {
                            enemyDamage = Math.floor(enemyDamage * 0.5);
                            player.health -= enemyDamage;
                            updateLog(`Вы БЛОКИРОВАЛИ атаку ${enemy.name}!`, "block");
                        } else {
                            player.health -= enemyDamage;
                            
                            if (isEnemyCritical) {
                                updateLog(`КРИТИЧЕСКИЙ УДАР! ${enemy.name} наносит ${enemyDamage} урона!`, "critical");
                            } else {
                                updateLog(`${enemy.name} наносит ${enemyDamage} урона!`, "combat");
                            }
                        }
                    }
                }
            });
            
            if (player.health <= 0) {
                player.health = 0;
                gameOver();
                return;
            }
            
            playerBerserkMode = false;
            playerDefensiveMode = false;
            
            updateHealthBars();
            updatePlayerStats();
            
            isPlayerTurn = true;
            updateLog("Ваш ход. Выберите действие.", "system");
        }

        function checkEnemyForQuest(enemy) {
            if (enemy.name === "Гоблин") {
                currentQuests.goblins.completed++;
                checkQuestCompletion("goblins");
            } else if (enemy.name === "Лесной волк") {
                currentQuests.wolves.completed++;
                checkQuestCompletion("wolves");
            } else if (enemy.name === "Бандит") {
                currentQuests.bandits.completed++;
                checkQuestCompletion("bandits");
            } else if (enemy.name === "Древний Страж") {
                currentQuests.boss.completed++;
                checkQuestCompletion("boss");
            }
        }

        function defeatEnemy() {
            player.gold += enemy.gold;
            player.exp += enemy.exp;
            
            checkEnemyForQuest(enemy);
            
            updateLog(`Вы победили ${enemy.name}! +${enemy.exp} опыта, +${enemy.gold} золота.`, "combat");
            showNotification(`Победа! +${enemy.exp} опыта, +${enemy.gold} золота.`);
            
            checkLevelUp();
            endCombat();
        }

        function victoryMassCombat() {
            const totalGold = enemiesInCombat.reduce((sum, e) => sum + e.gold, 0);
            const totalExp = enemiesInCombat.reduce((sum, e) => sum + e.exp, 0);
            
            player.gold += totalGold;
            player.exp += totalExp;
            
            updateLog(`🎉 Победа! Вы победили всех врагов!`, "combat");
            updateLog(`Награда: +${totalGold} золота, +${totalExp} опыта`, "loot");
            showNotification(`Победа в массовом бою! +${totalGold} золота, +${totalExp} опыта`);
            
            checkLevelUp();
            endMassCombat();
        }

        function endCombat() {
            inCombat = false;
            enemy = null;
            isPlayerTurn = true;
            updateLocation();
            updateHealthBars();
            saveGame();
        }

        function endMassCombat() {
            inCombat = false;
            enemiesInCombat = [];
            companionsInCombat = [];
            currentEnemyIndex = 0;
            
            document.getElementById("mass-combat-container").style.display = "none";
            updateLocation();
            updateHealthBars();
            saveGame();
        }

        function attemptEscape() {
            if (!inCombat) return;
            
            const escapeChance = 0.4 + (calculateStats().luck / 100);
            
            if (Math.random() < escapeChance) {
                updateLog("Вы успешно сбежали из боя!", "combat");
                showNotification("Вы успешно сбежали!");
                endCombat();
            } else {
                updateLog("Вам не удалось сбежать!", "combat");
                isPlayerTurn = false;
                setTimeout(() => enemyTurn(), 800);
            }
        }

        function attemptMassEscape() {
            if (!inCombat) return;
            
            const escapeChance = 0.3 + (calculateStats().luck / 100);
            
            if (Math.random() < escapeChance) {
                updateLog("Вы успешно отступили из боя!", "combat");
                showNotification("Вы успешно отступили!");
                endMassCombat();
            } else {
                updateLog("Вам не удалось отступить!", "combat");
                isPlayerTurn = false;
                setTimeout(() => massCombatEnemyTurn(), 800);
            }
        }

        // ============ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ============
        function calculateStats() {
            let attack = player.baseAttack;
            let defense = player.baseDefense;
            let luck = player.baseLuck;
            
            for (const slot in player.equipment) {
                const item = player.equipment[slot];
                if (item) {
                    if (item.attack) attack += item.attack;
                    if (item.defense) defense += item.defense;
                    if (item.luck) luck += item.luck;
                }
            }
            
            return { attack, defense, luck };
        }

        function usePotionFromInventory() {
            const potion = player.inventory.find(i => i.id === "health_potion");
            if (potion && (potion.count > 0 || !potion.count)) {
                const healAmount = 30;
                player.health = Math.min(player.maxHealth, player.health + healAmount);
                
                if (potion.count) {
                    potion.count--;
                    if (potion.count <= 0) {
                        player.inventory = player.inventory.filter(i => i !== potion);
                    }
                } else {
                    player.inventory = player.inventory.filter(i => i !== potion);
                }
                
                updateHealthBars();
                updateInventory();
                updateLog(`Вы использовали зелье здоровья! +${healAmount} HP`, "heal");
                showNotification(`Использовано зелье здоровья! +${healAmount} HP`);
                
                if (inCombat) {
                    isPlayerTurn = false;
                    if (enemiesInCombat.length > 0) {
                        setTimeout(() => massCombatEnemyTurn(), 800);
                    } else {
                        setTimeout(() => enemyTurn(), 800);
                    }
                }
                
                saveGame();
            } else {
                updateLog("У вас нет зелья здоровья!", "system");
                showNotification("У вас нет зелья здоровья!");
            }
        }

        function restAtVillage() {
            if (player.location !== "village") {
                updateLog("Отдыхать можно только в деревне!", "system");
                showNotification("Отдыхать можно только в деревне!");
                return;
            }
            
            const healed = player.maxHealth - player.health;
            player.health = player.maxHealth;
            updateHealthBars();
            updatePlayerStats();
            updateLog(`Вы отдохнули в деревне! +${healed} HP`, "heal");
            showNotification(`Здоровье восстановлено! +${healed} HP`);
            saveGame();
        }

        function exploreArea() {
            const random = Math.random();
            
            if (random < 0.4) {
                startCombatInLocation();
            } else if (random < 0.7) {
                const goldFound = Math.floor(Math.random() * 50) + 20;
                player.gold += goldFound;
                updatePlayerStats();
                updateLog(`Вы нашли ${goldFound} золота!`, "loot");
                showNotification(`Найдено ${goldFound} золота!`);
            } else if (random < 0.9) {
                // Находка предмета
                let qualityRoll = Math.random();
                let itemQuality = "common";
                
                if (qualityRoll < 0.01) itemQuality = "legendary";      // 1% шанс
                else if (qualityRoll < 0.05) itemQuality = "epic";      // 4% шанс
                else if (qualityRoll < 0.15) itemQuality = "rare";      // 10% шанс
                else if (qualityRoll < 0.4) itemQuality = "uncommon";   // 25% шанс
                else itemQuality = "common";                           // 60% шанс
                
                // Предметы по качеству
                const itemsByQuality = {
                    common: ["wooden_sword", "leather_armor", "leather_helmet", "wooden_shield", "health_potion"],
                    uncommon: ["iron_sword", "iron_armor", "lucky_amulet"],
                    rare: ["steel_sword", "steel_armor"],
                    epic: ["dragon_sword", "dragon_armor"],
                    legendary: ["excalibur", "god_armor"]
                };
                
                const items = itemsByQuality[itemQuality];
                if (items && items.length > 0) {
                    const itemId = items[Math.floor(Math.random() * items.length)];
                    const foundItem = createItem(itemId);
                    
                    player.inventory.push(foundItem);
                    totalItemsCollected++;
                    
                    updateInventory();
                    updateLog(`Вы нашли ${QUALITIES[itemQuality].name} предмет: ${foundItem.name}!`, "loot");
                    showNotification(`Найден ${QUALITIES[itemQuality].name.toLowerCase()} предмет: ${foundItem.name}!`);
                }
            } else {
                updateLog("Вы ничего не нашли.", "system");
            }
            
            saveGame();
        }

        function checkLevelUp() {
            if (player.exp >= player.expToNextLevel) {
                player.level++;
                player.exp -= player.expToNextLevel;
                player.expToNextLevel = Math.floor(player.expToNextLevel * 1.5);
                player.skillPoints += 3;
                
                updateLog(`🎉 Уровень ${player.level}! +3 очка характеристик`, "level");
                showNotification(`Поздравляем! Уровень ${player.level}!`);
                
                if (player.skillPoints > 0) {
                    openModal("level-up-modal");
                }
                
                updatePlayerStats();
                checkLevelUp(); // Рекурсивно проверяем еще раз
                saveGame();
            }
        }

        function gameOver() {
            updateLog("💀 Вы проиграли! Игра окончена.", "combat");
            showNotification("💀 Вы проиграли! Игра окончена.");
            
            inCombat = false;
            enemy = null;
            enemiesInCombat = [];
            
            const actionsGrid = document.getElementById("actions");
            actionsGrid.innerHTML = `<button class="action-btn" onclick="resetGame()">🔄 Начать заново</button>`;
            
            saveGame();
        }

        // ============ ИНВЕНТАРЬ И ЭКИПИРОВКА ============
        function updateEquipment() {
            const grid = document.getElementById("equipment");
            grid.innerHTML = "";
            
            const slots = [
                { id: "weapon", name: "Оружие", icon: "🗡️" },
                { id: "armor", name: "Броня", icon: "🥋" },
                { id: "helmet", name: "Шлем", icon: "⛑️" },
                { id: "shield", name: "Щит", icon: "🛡️" },
                { id: "boots", name: "Ботинки", icon: "👢" },
                { id: "gloves", name: "Перчатки", icon: "🧤" },
                { id: "ring", name: "Кольцо", icon: "💍" },
                { id: "amulet", name: "Амулет", icon: "📿" }
            ];
            
            slots.forEach(slot => {
                const item = player.equipment[slot.id];
                const element = document.createElement("div");
                element.className = `equipment-slot ${item ? 'equipped' : ''}`;
                element.innerHTML = `
                    <div>${slot.icon} ${slot.name}</div>
                    ${item ? 
                        `<div class="quality-${item.quality}">${item.name}</div>
                         <div style="font-size: 0.8rem; color: ${QUALITIES[item.quality].color};">
                            ${item.attack ? `⚔️+${item.attack} ` : ''}
                            ${item.defense ? `🛡️+${item.defense} ` : ''}
                            ${item.luck ? `🍀+${item.luck}` : ''}
                         </div>` : 
                        '<div style="color: #666; font-size: 0.9rem;">Пусто</div>'
                    }
                `;
                
                if (item) {
                    element.onclick = () => unequipItem(slot.id);
                }
                
                grid.appendChild(element);
            });
        }

        function updateInventory() {
            const grid = document.getElementById("inventory");
            grid.innerHTML = "";
            
            player.inventory.forEach((item, index) => {
                const element = document.createElement("div");
                element.className = `inventory-item ${item.equipped ? 'equipped' : ''}`;
                element.innerHTML = `
                    <div style="font-size: 1.5rem; margin-bottom: 5px;">${item.icon}</div>
                    <div class="quality-${item.quality}">${item.name}</div>
                    <div style="font-size: 0.8rem; color: ${QUALITIES[item.quality].color};">
                        ${item.attack ? `⚔️+${item.attack} ` : ''}
                        ${item.defense ? `🛡️+${item.defense} ` : ''}
                        ${item.luck ? `🍀+${item.luck} ` : ''}
                        ${item.health ? `❤️+${item.health} ` : ''}
                        ${item.count ? `×${item.count}` : ''}
                    </div>
                `;
                
                element.onclick = () => {
                    if (item.type === "potion") {
                        usePotionFromInventory();
                    } else if (item.equipped) {
                        unequipItemByItem(item);
                    } else {
                        equipItem(item);
                    }
                };
                
                grid.appendChild(element);
            });
            
            const emptySlots = 20 - player.inventory.length;
            for (let i = 0; i < emptySlots; i++) {
                const emptyElement = document.createElement("div");
                emptyElement.className = "inventory-item";
                emptyElement.innerHTML = `<div style="color: #666;">Пусто</div>`;
                grid.appendChild(emptyElement);
            }
        }

        function equipItem(item) {
            const slot = item.type;
            
            if (!player.equipment.hasOwnProperty(slot)) {
                updateLog(`Нельзя экипировать ${item.name} в этот слот`, "system");
                showNotification(`Нельзя экипировать ${item.name} в этот слот`);
                return;
            }
            
            if (player.equipment[slot]) {
                unequipItem(slot);
            }
            
            player.equipment[slot] = item;
            item.equipped = true;
            
            updatePlayerStats();
            updateEquipment();
            updateInventory();
            updateLog(`Вы экипировали: ${item.name}`, "equip");
            showNotification(`Экипирован: ${item.name}`);
            saveGame();
        }

        function unequipItem(slot) {
            const item = player.equipment[slot];
            if (!item) return;
            
            player.equipment[slot] = null;
            item.equipped = false;
            
            updatePlayerStats();
            updateEquipment();
            updateInventory();
            updateLog(`Вы сняли: ${item.name}`, "equip");
            showNotification(`Снят: ${item.name}`);
            saveGame();
        }

        function unequipItemByItem(item) {
            for (const slot in player.equipment) {
                if (player.equipment[slot] === item) {
                    unequipItem(slot);
                    return;
                }
            }
        }

        // ============ ПРОДАЖА ============
        function openSellModal() {
            if (player.location !== "village" && player.location !== "shop") {
                updateLog("Продавать можно только в деревне или магазине!", "system");
                showNotification("Продавать можно только в деревне или магазине!");
                return;
            }
            
            const modal = document.getElementById("sell-modal");
            modal.classList.add("active");
            updateSellModal();
        }

        function updateSellModal() {
            const container = document.getElementById("sell-items-container");
            const goldElement = document.getElementById("sell-gold-amount");
            
            goldElement.textContent = player.gold;
            container.innerHTML = "";
            
            const sellableItems = player.inventory.filter(item => !item.equipped);
            
            if (sellableItems.length === 0) {
                container.innerHTML = '<div style="text-align: center; padding: 20px; color: #999;">Нет предметов для продажи</div>';
                return;
            }
            
            sellableItems.forEach(item => {
                let sellPrice = 0;
                if (item.value) {
                    sellPrice = Math.floor(item.value * 0.7);
                } else {
                    const baseValue = (item.attack || 0) * 10 + (item.defense || 0) * 8 + (item.luck || 0) * 15;
                    sellPrice = Math.floor(baseValue * QUALITIES[item.quality].multiplier * 0.7);
                }
                
                if (sellPrice < 1) sellPrice = 1;
                
                const itemElement = document.createElement("div");
                itemElement.className = "inventory-item";
                itemElement.innerHTML = `
                    <div style="font-size: 1.5rem; margin-bottom: 5px;">${item.icon}</div>
                    <div class="quality-${item.quality}">${item.name}</div>
                    <div style="color: #ffd700; font-weight: bold; margin: 5px 0;">${sellPrice} золота</div>
                    <div style="font-size: 0.8rem; color: ${QUALITIES[item.quality].color};">
                        ${item.attack ? `⚔️+${item.attack} ` : ''}
                        ${item.defense ? `🛡️+${item.defense} ` : ''}
                        ${item.count ? `×${item.count}` : ''}
                    </div>
                `;
                
                itemElement.onclick = () => sellItem(item, sellPrice);
                container.appendChild(itemElement);
            });
        }

        function sellItem(item, price) {
            if (item.equipped) {
                updateLog("Нельзя продать экипированный предмет!", "system");
                showNotification("Нельзя продать экипированный предмет!");
                return;
            }
            
            const itemIndex = player.inventory.findIndex(i => i === item);
            if (itemIndex !== -1) {
                player.inventory.splice(itemIndex, 1);
                player.gold += price;
                
                updateLog(`Вы продали ${item.name} за ${price} золота.`, "shop");
                showNotification(`Продано: ${item.name} за ${price} золота.`);
                updatePlayerStats();
                updateInventory();
                updateSellModal();
                saveGame();
            }
        }

        // ============ ПОКУПКА ============
        const SHOP_ITEMS = {
            steel_sword: createItem("steel_sword"),
            steel_shield: createItem("steel_shield"),
            chain_armor: createItem("steel_armor"),
            iron_helmet: createItem("leather_helmet"),
            health_potion: createItem("health_potion")
        };

        function buyItem(itemId, cost) {
            const item = SHOP_ITEMS[itemId];
            if (!item) return;
            
            if (player.gold < cost) {
                updateLog(`Недостаточно золота! Нужно ${cost} золота.`, "system");
                showNotification(`Недостаточно золота! Нужно ${cost} золота.`);
                return;
            }
            
            player.gold -= cost;
            
            const purchasedItem = JSON.parse(JSON.stringify(item));
            purchasedItem.equipped = false;
            
            if (purchasedItem.id === "health_potion") {
                const existingPotion = player.inventory.find(i => i.id === "health_potion");
                if (existingPotion) {
                    existingPotion.count = (existingPotion.count || 1) + 1;
                } else {
                    purchasedItem.count = 1;
                    player.inventory.push(purchasedItem);
                }
            } else {
                player.inventory.push(purchasedItem);
            }
            
            updatePlayerStats();
            updateInventory();
            updateLog(`Вы купили ${item.name} за ${cost} золота.`, "shop");
            showNotification(`Куплен ${item.name} за ${cost} золота.`);
            saveGame();
        }

        // ============ КВЕСТЫ ============
        function updateQuests() {
            const container = document.getElementById("quests-container");
            container.innerHTML = "";
            
            Object.values(currentQuests).forEach(quest => {
                if (quest.status !== "inactive") {
                    const questElement = document.createElement("div");
                    questElement.className = `quest ${quest.status === "completed" ? "quest-completed" : ""}`;
                    
                    let progressText = "";
                    if (quest.type === "repeatable") {
                        progressText = `${quest.completed}/${quest.target} (повторяемый)`;
                    } else {
                        progressText = `${quest.completed}/${quest.target}`;
                    }
                    
                    questElement.innerHTML = `
                        <div style="font-weight: bold;">${quest.name}</div>
                        <div style="font-size: 0.8rem; color: #a3d9ff;">${progressText}</div>
                        <div style="font-size: 0.8rem; color: #2ecc71; margin-top: 5px;">${quest.description}</div>
                    `;
                    
                    container.appendChild(questElement);
                }
            });
        }

        function checkQuestCompletion(questId) {
            const quest = currentQuests[questId];
            
            if (quest.completed >= quest.target && quest.status === "active") {
                quest.status = "completed";
                
                player.gold += quest.reward.gold;
                player.exp += quest.reward.exp;
                
                updateLog(`🎉 Квест "${quest.name}" выполнен!`, "quest");
                showNotification(`Квест "${quest.name}" выполнен! Награда получена.`);
                updateLog(`Награда: ${quest.reward.gold} золота, ${quest.reward.exp} опыта`, "quest");
                
                if (quest.reward.item) {
                    const item = SHOP_ITEMS[quest.reward.item];
                    if (item) {
                        player.inventory.push({ ...item, equipped: false });
                        updateLog(`Дополнительная награда: ${item.name}!`, "loot");
                        showNotification(`Дополнительная награда: ${item.name}!`);
                        updateInventory();
                    }
                }
                
                if (quest.type === "repeatable") {
                    quest.completed = 0;
                    quest.status = "active";
                    updateLog(`Квест "${quest.name}" можно выполнить снова!`, "quest");
                    showNotification(`Квест "${quest.name}" можно выполнить снова!`);
                }
                
                updatePlayerStats();
                updateQuests();
                saveGame();
            }
        }

        // ============ ПРОКАЧКА ============
        function upgradeStat(stat) {
            if (player.skillPoints <= 0) return;
            
            switch(stat) {
                case "attack":
                    player.baseAttack += 2;
                    break;
                case "defense":
                    player.baseDefense += 2;
                    break;
                case "maxHealth":
                    player.maxHealth += 10;
                    player.health += 10;
                    break;
            }
            
            player.skillPoints--;
            updatePlayerStats();
            updateHealthBars();
            
            document.getElementById("modal-skill-points").textContent = player.skillPoints;
            document.getElementById("modal-remaining-points").textContent = player.skillPoints;
            
            if (player.skillPoints <= 0) {
                closeModal("level-up-modal");
            }
            
            saveGame();
        }

        // ============ МОДАЛЬНЫЕ ОКНА ============
        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            if (modal) {
                modal.classList.add("active");
                
                if (modalId === "map-modal") {
                    updateMap();
                }
            }
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            if (modal) {
                modal.classList.remove("active");
            }
        }

        function updateMap() {
            const mapGrid = document.getElementById("map-grid");
            mapGrid.innerHTML = "";
            
            const allLocations = [
                { id: "village", name: "Деревня", icon: "🏠", levelReq: 1 },
                { id: "forest", name: "Тёмный лес", icon: "🌲", levelReq: 1 },
                { id: "deepforest", name: "Глухой лес", icon: "🌳", levelReq: 2 },
                { id: "graveyard", name: "Кладбище", icon: "⚰️", levelReq: 3 },
                { id: "ruins", name: "Древние руины", icon: "🏛️", levelReq: 3 },
                { id: "cave", name: "Пещера", icon: "🕳️", levelReq: 4 },
                { id: "mountains", name: "Ледяные горы", icon: "⛰️", levelReq: 5 },
                { id: "volcano", name: "Вулкан", icon: "🌋", levelReq: 8 },
                { id: "castle", name: "Замок", icon: "🏰", levelReq: 6 },
                { id: "swamp", name: "Топкое болото", icon: "🐊", levelReq: 6 },
                { id: "desert", name: "Пустыня", icon: "🏜️", levelReq: 7 },
                { id: "shop", name: "Магазин", icon: "🏪", levelReq: 1 },
                { id: "tavern", name: "Таверна", icon: "🍺", levelReq: 1 }
            ];
            
            allLocations.forEach(loc => {
                const isCurrent = player.location === loc.id;
                const isDiscovered = player.discoveredLocations.includes(loc.id);
                const isAccessible = player.level >= loc.levelReq;
                
                const locationEl = document.createElement("div");
                locationEl.className = "inventory-item";
                if (isCurrent) locationEl.style.borderColor = "#ffd700";
                if (!isDiscovered || !isAccessible) locationEl.style.opacity = "0.5";
                
                locationEl.innerHTML = `
                    <div style="font-size: 1.5rem;">${loc.icon}</div>
                    <div>${loc.name}</div>
                    <div style="font-size: 0.8rem; color: ${isAccessible ? '#2ecc71' : '#e74c3c'}">
                        Ур. ${loc.levelReq}
                    </div>
                `;
                
                if (isDiscovered && isAccessible && !isCurrent) {
                    locationEl.onclick = () => {
                        if (inCombat) {
                            updateLog("Нельзя перемещаться во время боя!", "system");
                            showNotification("Нельзя перемещаться во время боя!");
                            return;
                        }
                        player.location = loc.id;
                        updateLocation();
                        closeModal("map-modal");
                        updateLog(`Вы переместились в: ${loc.name}`, "system");
                    };
                }
                
                mapGrid.appendChild(locationEl);
            });
        }

        // ============ ЛОГ ============
        function updateLog(message, type = "system") {
            const logEl = document.getElementById("log");
            const entry = document.createElement("div");
            entry.className = `log-entry log-${type}`;
            entry.textContent = `> ${message}`;
            
            logEl.appendChild(entry);
            logEl.scrollTop = logEl.scrollHeight;
            
            if (logEl.children.length > 20) {
                logEl.removeChild(logEl.firstChild);
            }
        }

        // ============ СОХРАНЕНИЕ И ЗАГРУЗКА ============
        function saveGame() {
            try {
                const gameData = {
                    player: player,
                    currentQuests: currentQuests,
                    totalItemsCollected: totalItemsCollected,
                    version: VERSION,
                    timestamp: Date.now()
                };
                
                localStorage.setItem(SAVE_KEY, JSON.stringify(gameData));
                console.log("Игра сохранена:", gameData);
            } catch (e) {
                console.error("Ошибка сохранения:", e);
            }
        }

        function loadGame() {
            try {
                const savedData = localStorage.getItem(SAVE_KEY);
                
                if (savedData) {
                    const gameData = JSON.parse(savedData);
                    
                    if (gameData.version === VERSION) {
                        player = gameData.player;
                        currentQuests = gameData.currentQuests;
                        totalItemsCollected = gameData.totalItemsCollected || 0;
                        
                        // Восстанавливаем значения по умолчанию, если их нет
                        if (!player.discoveredLocations) player.discoveredLocations = ["village", "forest", "shop", "tavern"];
                        if (!player.equipment) player.equipment = {
                            weapon: null, armor: null, helmet: null, shield: null,
                            boots: null, gloves: null, ring: null, amulet: null
                        };
                        if (!player.inventory) player.inventory = [];
                        if (!player.companions) player.companions = [];
                        if (!player.maxCompanions) player.maxCompanions = 3;
                        if (!player.reputation) player.reputation = {
                            village: 0, warriors: 0, mages: 0, merchants: 0
                        };
                        
                        // Убеждаемся, что у всех предметов есть качество
                        player.inventory.forEach(item => {
                            if (!item.quality) item.quality = "common";
                        });
                        
                        updateLog("Игра загружена из сохранения!", "system");
                        console.log("Игра загружена:", gameData);
                    } else {
                        updateLog("Версия сохранения не совпадает, начинаем новую игру", "system");
                        player = initPlayer();
                        currentQuests = initQuests();
                    }
                } else {
                    updateLog("Сохранение не найдено, начинаем новую игру", "system");
                    player = initPlayer();
                    currentQuests = initQuests();
                }
            } catch (e) {
                console.error("Ошибка загрузки:", e);
                updateLog("Ошибка загрузки сохранения, начинаем новую игру", "system");
                player = initPlayer();
                currentQuests = initQuests();
            }
        }

        function resetGame() {
            if (confirm("Начать новую игру? Текущий прогресс будет потерян.")) {
                localStorage.removeItem(SAVE_KEY);
                player = initPlayer();
                currentQuests = initQuests();
                
                enemy = null;
                enemiesInCombat = [];
                companionsInCombat = [];
                currentEnemyIndex = 0;
                inCombat = false;
                isPlayerTurn = true;
                playerBerserkMode = false;
                playerDefensiveMode = false;
                totalItemsCollected = 0;

                initGame();
                updateLog("Новая игра начата!", "system");
                showNotification("Новая игра начата!");
            }
        }

        // ============ ЗАПУСК ИГРЫ ============
        document.addEventListener("DOMContentLoaded", initGame);
    </script>
</body>
</html>
