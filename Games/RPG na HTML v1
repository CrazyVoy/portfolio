            const stats = calculateStats();
            
            document.getElementById("level").textContent = player.level;
            document.getElementById("exp").textContent = `${player.exp}/${player.expToNextLevel}`;
            document.getElementById("gold").textContent = player.gold;
            document.getElementById("attack").textContent = stats.attack;
            document.getElementById("defense").textContent = stats.defense;
            document.getElementById("companion-count").textContent = `${player.companions.length}/${player.maxCompanions}`;
            
            const expPercent = Math.min(100, (player.exp / player.expToNextLevel) * 100);
            document.getElementById("exp-bar").style.width = `${expPercent}%`;
            document.getElementById("exp-percent").textContent = `${Math.floor(expPercent)}%`;
            
            if (player.skillPoints > 0) {
                document.getElementById("skill-points").style.display = "block";
                document.getElementById("available-points").textContent = player.skillPoints;
                document.getElementById("modal-skill-points").textContent = player.skillPoints;
                document.getElementById("modal-remaining-points").textContent = player.skillPoints;
            } else {
                document.getElementById("skill-points").style.display = "none";
            }
        }

        function updateHealthBars() {
            const playerHealthPercent = (player.health / player.maxHealth) * 100;
            document.getElementById("player-health-text").textContent = `${player.health}/${player.maxHealth}`;
            document.getElementById("player-health-bar").style.width = `${playerHealthPercent}%`;
            
            if (enemy) {
                document.getElementById("enemy-health-container").style.display = "block";
                document.getElementById("enemy-name-text").textContent = `${enemy.name}:`;
                document.getElementById("enemy-health-text").textContent = `${enemy.health}/${enemy.maxHealth}`;
                const enemyHealthPercent = (enemy.health / enemy.maxHealth) * 100;
                document.getElementById("enemy-health-bar").style.width = `${enemyHealthPercent}%`;
            } else {
                document.getElementById("enemy-health-container").style.display = "none";
            }
        }

        function updateLocation() {
            const location = LOCATIONS[player.location];
            if (!location) return;
            
            document.getElementById("location").textContent = location.name;
            document.getElementById("description").textContent = location.description;
            
            const actionsGrid = document.getElementById("actions");
            actionsGrid.innerHTML = "";
            
            if (inCombat) {
                if (enemiesInCombat.length > 0) {
                    // Массовый бой
                    actionsGrid.innerHTML = `
                        <button class="action-btn combat-btn" onclick="massCombatAttack()">⚔️ Атаковать</button>
                        <button class="action-btn" onclick="massCombatBerserk()">🔥 Мощная атака</button>
                        <button class="action-btn" onclick="usePotionFromInventory()">🧪 Исп. зелье</button>
                        <button class="action-btn" onclick="attemptMassEscape()">🏃 Отступить</button>
                    `;
                } else {
                    // Одиночный бой
                    actionsGrid.innerHTML = `
                        <button class="action-btn combat-btn" onclick="playerAttack()">⚔️ Обычная атака</button>
                        <button class="action-btn" onclick="playerBerserkAttack()">🔥 Удар берсерка</button>
                        <button class="action-btn" onclick="playerDefensiveAttack()">🛡️ Оборонительный удар</button>
                        <button class="action-btn" onclick="usePotionFromInventory()">🧪 Исп. зелье здоровья</button>
                        <button class="action-btn" onclick="attemptEscape()">🏃 Попытаться сбежать</button>
                    `;
                }
            } else {
                // Обычные действия
                location.actions.forEach(action => {
                    const button = document.createElement("button");
                    button.className = "action-btn";
                    button.textContent = action.text;
                    button.onclick = () => handleAction(action);
                    actionsGrid.appendChild(button);
                });
            }
        }

        // ============ ОБРАБОТКА ДЕЙСТВИЙ ============
        function handleAction(action) {
            switch(action.action) {
                case "go":
                    goToLocation(action.target);
                    break;
                case "rest":
                    restAtVillage();
                    break;
                case "hunt":
                    startCombatInLocation();
                    break;
                case "search":
                case "explore":
                    exploreArea();
                    break;
                case "boss":
                    if (player.level >= 5) {
                        startCombat("boss");
                    } else {
                        updateLog("Для сражения с боссом нужен 5 уровень!", "system");
                        showNotification("Требуется 5 уровень для сражения с боссом!");
                    }
                    break;
                case "talk":
                    talkToNPC(action.target);
                    break;
                case "buy":
                    buyItem(action.target, action.cost);
                    break;
                case "sell":
                    openSellModal();
                    break;
                case "view_companions":
                    showTavernCompanions();
                    break;
                case "drink":
                    drinkAle();
                    break;
                case "listen_bard":
                    listenToBard();
                    break;
                case "talk_patrons":
                    talkToPatrons();
                    break;
            }
        }

        // ============ ПЕРЕМЕЩЕНИЕ ============
        function goToLocation(locationId) {
            if (inCombat) {
                updateLog("Нельзя перемещаться во время боя!", "system");
                showNotification("Нельзя перемещаться во время боя!");
                return;
            }
            
            const targetLocation = LOCATIONS[locationId];
            if (!targetLocation) return;
            
            if (player.level < targetLocation.minLevel) {
                updateLog(`Для посещения этой локации нужен ${targetLocation.minLevel} уровень!`, "system");
                showNotification(`Требуется ${targetLocation.minLevel} уровень!`);
                return;
            }
            
            player.location = locationId;
            if (!player.discoveredLocations.includes(locationId)) {
                player.discoveredLocations.push(locationId);
                updateLog(`Вы открыли новую локацию: ${targetLocation.name}!`, "loot");
                showNotification(`Открыта новая локация: ${targetLocation.name}!`);
                
                // Активируем квесты при открытии новых локаций
                if (locationId === "deepforest") {
                    currentQuests.bandits.status = "active";
                    updateLog("Новый квест: 'Бандитская засада'!", "quest");
                    showNotification("Новый квест: 'Бандитская засада'!");
                }
                if (locationId === "ruins") {
                    currentQuests.artifact.status = "active";
                    updateLog("Новый квест: 'Поиск артефакта'!", "quest");
                    showNotification("Новый квест: 'Поиск артефакта'!");
                }
                if (locationId === "cave") {
                    currentQuests.boss.status = "active";
                    updateLog("Новый квест: 'Победа над боссом'!", "quest");
                    showNotification("Новый квест: 'Победа над боссом'!");
                }
            }
            
            updateLocation();
            updateQuests();
            updateLog(`Вы переместились в: ${targetLocation.name}`, "system");
            
            saveGame(); // Сохраняем после перемещения
        }

        function goToTavern() {
            goToLocation("tavern");
        }

        // ============ ТАВЕРНА ============
        function showTavernCompanions() {
            const actionsGrid = document.getElementById("actions");
            actionsGrid.innerHTML = '<h2 style="text-align: center; margin-bottom: 15px;">👥 Нанять спутников</h2>';
            
            const tavernContent = document.createElement("div");
            tavernContent.className = "tavern-grid";
            
            Object.values(COMPANIONS).forEach(companion => {
                const isHired = player.companions.some(c => c.id === companion.id);
                const canHire = !isHired && player.companions.length < player.maxCompanions;
                
