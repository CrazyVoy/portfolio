<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>RPG: Странник Пустошей v3.1</title>
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>⚔️</text></svg>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }

        body {
            background-color: #0a0a1a;
            color: #e6e6e6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            min-height: 100vh;
            padding: 10px;
            background-image: radial-gradient(circle at 20% 30%, #1a1a2e 0%, #0a0a1a 40%);
        }

        .game-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            padding: 15px;
            background: linear-gradient(135deg, #16213e 0%, #0f3460 100%);
            border-radius: 15px;
            margin-bottom: 20px;
            border: 2px solid #2d4059;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.5);
        }

        h1 {
            color: #ffd700;
            text-shadow: 2px 2px 4px #000;
            margin-bottom: 5px;
            font-size: 2rem;
        }

        .subtitle {
            color: #a3d9ff;
            font-style: italic;
        }

        .panels {
            display: grid;
            grid-template-columns: 1fr 2fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
        }

        @media (max-width: 900px) {
            .panels {
                grid-template-columns: 1fr;
            }
        }

        .panel {
            background: linear-gradient(145deg, #16213e, #0f3460);
            border-radius: 15px;
            padding: 20px;
            border: 2px solid #2d4059;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        h2 {
            color: #ffd700;
            border-bottom: 3px solid #0f3460;
            padding-bottom: 10px;
            margin-bottom: 20px;
            font-size: 1.4rem;
        }

        /* Статистика */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .stat {
            background: rgba(15, 52, 96, 0.7);
            padding: 12px;
            border-radius: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stat-value {
            color: #ffd700;
            font-weight: bold;
        }

        /* Здоровье */
        .health-bars {
            background: rgba(15, 52, 96, 0.7);
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
        }

        .health-container {
            margin-bottom: 15px;
        }

        .health-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-weight: bold;
        }

        .health-bar {
            height: 25px;
            background: rgba(0, 0, 0, 0.5);
            border-radius: 12px;
            overflow: hidden;
        }

        .health-fill {
            height: 100%;
            transition: width 0.5s ease;
        }

        .player-health {
            background: linear-gradient(90deg, #e74c3c, #ff6b6b);
        }

        .enemy-health {
            background: linear-gradient(90deg, #9b59b6, #8e44ad);
        }

        /* Действия */
        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin-bottom: 20px;
        }

        .action-btn {
            background: linear-gradient(135deg, #0f3460, #16213e);
            border: none;
            color: white;
            padding: 15px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
            border: 2px solid transparent;
            font-weight: bold;
        }

        .action-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
        }

        .combat-btn {
            background: linear-gradient(135deg, #c0392b, #e74c3c);
        }

        .tavern-btn {
            background: linear-gradient(135deg, #e67e22, #d35400);
        }

        .talk-btn {
            background: linear-gradient(135deg, #3498db, #2980b9);
        }

        .map-btn {
            background: linear-gradient(135deg, #8e44ad, #9b59b6);
        }

        .heal-btn {
            background: linear-gradient(135deg, #27ae60, #2ecc71);
        }

        /* Лог */
        .log {
            background: rgba(15, 15, 30, 0.9);
            padding: 15px;
            border-radius: 10px;
            border: 1px solid #2d4059;
            max-height: 200px;
            overflow-y: auto;
        }

        .log-entry {
            padding: 8px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .log-combat { color: #ff9999; }
        .log-critical { color: #ff0000; font-weight: bold; }
        .log-dodge { color: #00ccff; }
        .log-block { color: #ffff00; }
        .log-berserk { color: #ff6600; }
        .log-loot { color: #99ff99; }
        .log-level { color: #99ccff; }
        .log-heal { color: #2ecc71; }
        .log-equip { color: #ffd700; }
        .log-quest { color: #ff99cc; }
        .log-shop { color: #ffcc00; }
        .log-system { color: #a3d9ff; }

        /* Экипировка */
        .equipment-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }

        .equipment-slot {
            background: rgba(15, 52, 96, 0.7);
            border: 2px dashed #2d4059;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            min-height: 100px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            cursor: pointer;
        }

        .equipment-slot.equipped {
            border: 2px solid #27ae60;
            background: rgba(39, 174, 96, 0.1);
        }

        /* Инвентарь */
        .inventory-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 10px;
            margin-bottom: 20px;
        }

        .inventory-item {
            background: rgba(15, 52, 96, 0.7);
            border: 2px solid #2d4059;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100px;
        }

        .inventory-item:hover {
            transform: translateY(-5px);
            border-color: #ffd700;
        }

        .inventory-item.equipped {
            border-color: #27ae60;
            background: rgba(39, 174, 96, 0.1);
        }

        /* Цвета качеств */
        .quality-common { color: #999999; border-left: 3px solid #999999; padding-left: 5px; }
        .quality-uncommon { color: #2ecc71; border-left: 3px solid #2ecc71; padding-left: 5px; }
        .quality-rare { color: #3498db; border-left: 3px solid #3498db; padding-left: 5px; }
        .quality-epic { color: #9b59b6; border-left: 3px solid #9b59b6; padding-left: 5px; }
        .quality-legendary { color: #f1c40f; border-left: 3px solid #f1c40f; padding-left: 5px; }

        /* Квесты */
        .quests {
            margin-top: 20px;
        }

        .quest {
            background: rgba(15, 52, 96, 0.7);
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 10px;
        }

        .quest-completed {
            border-left: 4px solid #27ae60;
            background: rgba(39, 174, 96, 0.2);
        }

        /* Кнопки управления */
        .control-buttons {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 20px;
        }

        .control-btn {
            background: linear-gradient(135deg, #2d4059, #3a4f6e);
            border: none;
            color: white;
            padding: 12px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: bold;
        }

        .control-btn:hover {
            background: linear-gradient(135deg, #3a4f6e, #2d4059);
            transform: translateY(-2px);
        }

        /* Массовые бои */
        .enemies-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 15px;
            margin: 20px 0;
        }

        .enemy-mini {
            width: 100px;
            background: rgba(44, 0, 62, 0.8);
            border: 2px solid #9b59b6;
            border-radius: 10px;
            padding: 10px;
            text-align: center;
            cursor: pointer;
        }

        .enemy-mini.active {
            border-color: #ff6b6b;
            box-shadow: 0 0 10px rgba(255, 107, 107, 0.5);
        }

        .enemy-mini.defeated {
            opacity: 0.4;
            filter: grayscale(1);
        }

        .enemy-mini-image {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            overflow: hidden;
            margin: 0 auto 5px;
            border: 2px solid #9b59b6;
        }

        .enemy-mini-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Таверна */
        .tavern-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .companion-card {
            background: linear-gradient(135deg, #16213e, #0f3460);
            border: 2px solid #2d4059;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
        }

        .companion-card.available {
            border-color: #27ae60;
        }

        .companion-card.hired {
            border-color: #ffd700;
            background: linear-gradient(135deg, #2c003e, #4a0072);
        }

        .companion-image {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            overflow: hidden;
            margin: 0 auto 10px;
            border: 3px solid #2d4059;
        }

        .companion-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .companion-hire-btn {
            background: linear-gradient(135deg, #27ae60, #2ecc71);
            border: none;
            color: white;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            width: 100%;
            margin-top: 10px;
        }

        .companion-hire-btn:disabled {
            background: linear-gradient(135deg, #7f8c8d, #95a5a6);
            cursor: not-allowed;
        }

        /* Модальные окна */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.9);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .modal.active {
            display: flex;
            animation: fadeIn 0.3s;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-content {
            background: linear-gradient(135deg, #0a0a1a, #1a1a2e);
            border-radius: 20px;
            padding: 30px;
            max-width: 800px;
            width: 100%;
            border: 3px solid #2d4059;
            max-height: 80vh;
            overflow-y: auto;
        }

        /* Полоса опыта */
        .exp-bar-container {
            margin-bottom: 15px;
        }

        .exp-bar {
            height: 10px;
            background: rgba(0, 0, 0, 0.5);
            border-radius: 5px;
            overflow: hidden;
            margin-top: 5px;
        }

        .exp-fill {
            height: 100%;
            background: linear-gradient(90deg, #3498db, #2ecc71);
            transition: width 0.5s;
        }

        /* Уведомления */
        .notification {
            position: fixed;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(15, 52, 96, 0.9);
            border: 2px solid #2d4059;
            border-radius: 10px;
            padding: 15px;
            color: white;
            z-index: 1001;
            display: none;
            max-width: 90%;
            text-align: center;
        }

        .notification.active {
            display: block;
            animation: slideUp 0.3s;
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateX(-50%) translateY(100%); }
            to { opacity: 1; transform: translateX(-50%) translateY(0); }
        }
    </style>
</head>
<body>
    <!-- Модальные окна -->
    <div class="modal" id="map-modal">
        <div class="modal-content">
            <h2 style="text-align: center; margin-bottom: 20px;">🗺️ Карта Пустошей</h2>
            <div class="map-grid" id="map-grid"></div>
            <button class="action-btn" onclick="closeModal('map-modal')" style="margin-top: 20px; width: 100%;">
                Закрыть карту
            </button>
        </div>
    </div>

    <div class="modal" id="level-up-modal">
        <div class="modal-content">
            <h2 style="text-align: center; margin-bottom: 20px;">🎉 Повышение уровня!</h2>
            <div class="stat" style="text-align: center; margin-bottom: 20px; background: rgba(142, 68, 173, 0.3);">
                <span>Очков характеристик:</span>
                <span class="stat-value" id="modal-skill-points">0</span>
            </div>
            <div style="margin-bottom: 20px;">
                <button class="action-btn" onclick="upgradeStat('attack')" style="width: 100%; margin-bottom: 10px;">
                    ⚔️ Увеличить атаку (+2)
                </button>
                <button class="action-btn" onclick="upgradeStat('defense')" style="width: 100%; margin-bottom: 10px;">
                    🛡️ Увеличить защиту (+2)
                </button>
                <button class="action-btn" onclick="upgradeStat('maxHealth')" style="width: 100%;">
                    ❤️ Увеличить здоровье (+10)
                </button>
            </div>
            <button class="action-btn" onclick="closeModal('level-up-modal')" style="width: 100%;">
                Закрыть (<span id="modal-remaining-points">0</span> очков осталось)
            </button>
        </div>
    </div>

    <div class="modal" id="sell-modal">
        <div class="modal-content">
            <h2 style="text-align: center; margin-bottom: 20px;">💰 Продажа предметов</h2>
            <div class="stat" style="text-align: center; margin-bottom: 20px; display: inline-block;">
                <span>Ваше золото:</span>
                <span class="stat-value" id="sell-gold-amount">0</span>
            </div>
            <div id="sell-items-container"></div>
            <button class="action-btn" onclick="closeModal('sell-modal')" style="margin-top: 20px; width: 100%;">
                Закрыть
            </button>
        </div>
    </div>

    <!-- Уведомление -->
    <div class="notification" id="notification">
        <span id="notification-text"></span>
    </div>

    <!-- Основной контейнер игры -->
    <div class="game-container">
        <header>
            <h1>⚔️ Странник Пустошей v3.1</h1>
            <p class="subtitle">Полный функционал с сохранением, картинками и 15+ локациями!</p>
        </header>

        <div class="panels">
            <!-- Левая панель -->
            <div class="panel">
                <h2>👤 Персонаж</h2>
                
                <div class="stats-grid">
                    <div class="stat">
                        <span>Уровень</span>
                        <span class="stat-value" id="level">1</span>
                    </div>
                    <div class="stat">
                        <span>Опыт</span>
                        <span class="stat-value" id="exp">0/100</span>
                    </div>
                    <div class="stat">
                        <span>Золото</span>
                        <span class="stat-value" id="gold">50</span>
                    </div>
                    <div class="stat">
                        <span>Атака</span>
                        <span class="stat-value" id="attack">10</span>
                    </div>
                    <div class="stat">
                        <span>Защита</span>
                        <span class="stat-value" id="defense">5</span>
                    </div>
                    <div class="stat">
                        <span>Спутники</span>
                        <span class="stat-value" id="companion-count">0/3</span>
                    </div>
                </div>

                <div class="exp-bar-container">
                    <div class="health-header">
                        <span>Прогресс до уровня:</span>
                        <span id="exp-percent">0%</span>
                    </div>
                    <div class="exp-bar">
                        <div class="exp-fill" id="exp-bar" style="width: 0%"></div>
                    </div>
                </div>

                <div id="skill-points" style="display: none; margin-bottom: 15px;">
                    <div class="stat" style="background: rgba(142, 68, 173, 0.3); border: 2px solid #8e44ad;">
                        <span>🎯 Очков характеристик:</span>
                        <span class="stat-value" id="available-points">0</span>
                    </div>
                    <button class="action-btn" onclick="openModal('level-up-modal')" style="margin-top: 10px; width: 100%;">
                        Распределить очки
                    </button>
                </div>

                <h2>👥 Спутники</h2>
                <div class="inventory-grid" id="companions-container"></div>

                <h2>🎒 Экипировка</h2>
                <div class="equipment-grid" id="equipment"></div>
            </div>

            <!-- Центральная панель -->
            <div class="panel">
                <div class="location-display">
                    <div class="location-name" id="location">Начальная деревня</div>
                    <div class="location-description" id="description">
                        Вы находитесь в мирной деревне на краю Пустошей.
                    </div>
                </div>

                <!-- Массовые враги -->
                <div id="mass-combat-container" style="display: none;">
                    <div class="enemies-container" id="enemies-container"></div>
                </div>

                <div class="health-bars">
                    <div class="health-container">
                        <div class="health-header">
                            <span>❤️ Ваше здоровье:</span>
                            <span id="player-health-text">100/100</span>
                        </div>
                        <div class="health-bar">
                            <div class="health-fill player-health" id="player-health-bar" style="width: 100%"></div>
                        </div>
                    </div>
                    
                    <div class="health-container" id="enemy-health-container" style="display: none;">
                        <div class="health-header">
                            <span id="enemy-name-text">Враг:</span>
                            <span id="enemy-health-text">0/0</span>
                        </div>
                        <div class="health-bar">
                            <div class="health-fill enemy-health" id="enemy-health-bar" style="width: 100%"></div>
                        </div>
                    </div>
                </div>

                <div class="actions-grid" id="actions"></div>

                <div class="log" id="log">
                    <div class="log-entry log-system">Добро пожаловать в "Странник Пустошей v3.1"!</div>
                    <div class="log-entry log-system">Все функции работают, данные сохраняются!</div>
                </div>
            </div>

            <!-- Правая панель -->
            <div class="panel">
                <h2>🎒 Инвентарь</h2>
                <div class="inventory-grid" id="inventory"></div>

                <h2>📜 Квесты</h2>
                <div class="quests" id="quests-container"></div>

                <div class="control-buttons">
                    <button class="control-btn tavern-btn" onclick="goToTavern()">🍺 Таверна</button>
                    <button class="control-btn talk-btn" onclick="talkToRandomNPC()">🗣️ Поговорить</button>
                    <button class="control-btn map-btn" onclick="openModal('map-modal')">🗺️ Карта</button>
                    <button class="control-btn heal-btn" onclick="restAtVillage()">💤 Отдохнуть</button>
                    <button class="control-btn" onclick="openSellModal()">💰 Продать</button>
                    <button class="control-btn" onclick="saveGame()">💾 Сохранить</button>
                    <button class="control-btn" onclick="loadGame()">📂 Загрузить</button>
                    <button class="control-btn" onclick="resetGame()">🔄 Новая</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ============ КОНСТАНТЫ И ПЕРЕМЕННЫЕ ============
        const VERSION = "3.1";
        const SAVE_KEY = "wastelandWandererSave_" + VERSION;
        
        // Картинки монстров
        const MONSTER_IMAGES = {
            goblin: "https://i.imgur.com/Q1VlVqS.png",
            wolf: "https://i.imgur.com/7Q8r2Wm.png",
            bandit: "https://i.imgur.com/9zV8L4t.png",
            skeleton: "https://i.imgur.com/3qJZc6R.png",
            troll: "https://i.imgur.com/1X7vD8L.png",
            ghost: "https://i.imgur.com/5tM3LpK.png",
            zombie: "https://i.imgur.com/8rV4N2q.png",
            scorpion: "https://i.imgur.com/2vG7p9J.png",
            mummy: "https://i.imgur.com/6W4tN8z.png",
            elemental: "https://i.imgur.com/4qX7v9L.png",
            dragon: "https://i.imgur.com/9tV4Z8R.png",
            dark_knight: "https://i.imgur.com/7V9pL2q.png",
            boss: "https://i.imgur.com/8rV9L2q.png"
        };

        // Резервные эмодзи
        const MONSTER_EMOJIS = {
            goblin: "👹", wolf: "🐺", bandit: "🗡️", skeleton: "🦴", troll: "👹",
            ghost: "👻", zombie: "🧟", scorpion: "🦂", mummy: "🧟", elemental: "🔥",
            dragon: "🐉", dark_knight: "🛡️", boss: "🐉"
        };

        // Качества предметов
        const QUALITIES = {
            common: { name: "Обычный", color: "#999999", multiplier: 1.0 },
            uncommon: { name: "Необычный", color: "#2ecc71", multiplier: 1.3 },
            rare: { name: "Редкий", color: "#3498db", multiplier: 1.7 },
            epic: { name: "Эпический", color: "#9b59b6", multiplier: 2.2 },
            legendary: { name: "Легендарный", color: "#f1c40f", multiplier: 3.0 }
        };

        // Игровые переменные
        let player = null;
        let enemy = null;
        let enemiesInCombat = [];
        let currentEnemyIndex = 0;
