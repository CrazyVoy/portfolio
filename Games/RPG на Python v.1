import random
import time
from collections import defaultdict

class Hero:
    def __init__(self):
        self.name = "Герой"
        self.max_hp = 100
        self.hp = 100
        self.base_min_dmg = 5
        self.base_max_dmg = 10
        self.dodge_chance = 5  # 5%
        self.base_defense = 0
        self.crit_chance = 5  # 5%
        self.equipment = {
            'weapon': None,
            'shield': None,
            'armor': None,
            'boots': None,
            'ring': None,
            'amulet': None
        }
        self.active_effects = defaultdict(list)
        self.inventory = []
        self.gold = 0
        self.xp = 0
        self.level = 1
        self.xp_to_level = 100
        self.dungeon_keys = 0
        self.current_dungeon_floor = 0
        self.companions = []
        self.available_companions = [
            Companion("Воин", 50, 5, 10, 100),
            Companion("Лучник", 40, 6, 12, 120),
            Companion("Маг", 35, 8, 15, 150),
            Companion("Лекарь", 45, 3, 6, 200),
            Companion("Защитник", 70, 4, 8, 180)
        ]
        
    @property
    def min_dmg(self):
        bonus = sum(effect.get('min_dmg', 0) for effects in self.active_effects.values() for effect in effects)
        weapon_bonus = self.equipment['weapon'].stats['min_dmg'] if self.equipment['weapon'] else 0
        return self.base_min_dmg + bonus + weapon_bonus
    
    @property
    def max_dmg(self):
        bonus = sum(effect.get('max_dmg', 0) for effects in self.active_effects.values() for effect in effects)
        weapon_bonus = self.equipment['weapon'].stats['max_dmg'] if self.equipment['weapon'] else 0
        return self.base_max_dmg + bonus + weapon_bonus
    
    @property
    def defense(self):
        bonus = sum(effect.get('defense', 0) for effects in self.active_effects.values() for effect in effects)
        armor_bonus = self.equipment['armor'].stats['defense'] if self.equipment['armor'] else 0
        boots_bonus = self.equipment['boots'].stats['defense'] if self.equipment['boots'] else 0
        return self.base_defense + bonus + armor_bonus + boots_bonus
    
    @property
    def dodge_chance_total(self):
        bonus = sum(effect.get('dodge', 0) for effects in self.active_effects.values() for effect in effects)
        boots_bonus = self.equipment['boots'].stats['dodge'] if self.equipment['boots'] else 0
        return self.dodge_chance + bonus + boots_bonus
    
    @property
    def crit_chance_total(self):
        bonus = sum(effect.get('crit', 0) for effects in self.active_effects.values() for effect in effects)
        ring_bonus = self.equipment['ring'].stats['crit'] if self.equipment['ring'] else 0
        amulet_bonus = self.equipment['amulet'].stats['crit'] if self.equipment['amulet'] else 0
        return self.crit_chance + bonus + ring_bonus + amulet_bonus
    
    def attack(self):
        is_crit = random.randint(1, 100) <= self.crit_chance_total
        damage = random.randint(self.min_dmg, self.max_dmg)
        if is_crit:
            damage += damage  # Удваиваем урон (добавляем к базовому)
            print("Критический удар!")
        return damage
    
    def take_damage(self, damage):
        if random.randint(1, 100) <= self.dodge_chance_total:
            print(f"{self.name} уклонился от атаки!")
            return 0
        
        if self.equipment['shield']:
            if random.randint(1, 100) <= self.equipment['shield'].block_chance:
                print(f"{self.name} блокировал атаку щитом!")
                damage = max(1, damage // 2)
        
        damage = max(1, damage - self.defense)
        self.hp -= damage
        return damage
    
    def update_effects(self):
        expired_effects = []
        for effect_name, effects in list(self.active_effects.items()):
            for effect in effects[:]:
                effect['duration'] -= 1
                if effect['duration'] <= 0:
                    expired_effects.append((effect_name, effect))
        
        for effect_name, effect in expired_effects:
            
            if effect_name in self.active_effects and effect in self.active_effects[effect_name]:
                self.active_effects[effect_name].remove(effect)
                print(f"Эффект {effect_name} закончился")
    
    def add_effect(self, name, duration, **stats):
        self.active_effects[name].append({'duration': duration, **stats})
        stat_changes = []
        if 'min_dmg' in stats or 'max_dmg' in stats:
            stat_changes.append(f"урон +{stats.get('min_dmg', stats.get('max_dmg', 0))}")
        if 'dodge' in stats:
            stat_changes.append(f"уворот +{stats['dodge']}%")
        if 'defense' in stats:
            stat_changes.append(f"защита +{stats['defense']}")
        if 'crit' in stats:
            stat_changes.append(f"крит +{stats['crit']}%")
        
        print(f"Получен эффект {name} на {duration} ходов: {', '.join(stat_changes)}")

    def is_alive(self):
        return self.hp > 0
    
    def heal(self, amount):
        self.hp = min(self.max_hp, self.hp + amount)
    
    def add_item(self, item):
        self.inventory.append(item)
        print(f"Получен предмет: {item.name}")
    
    def equip_item(self, item):
        if not item or item.type not in ['weapon', 'shield', 'armor', 'boots', 'ring', 'amulet']:
            print("Нельзя экипировать этот предмет")
            return False
            
        if item.required_level > self.level:
            print(f"Для экипировки {item.name} требуется {item.required_level} уровень")
            return False
        
        if item.slot not in self.equipment:
            print(f"Нет слота для этого предмета: {item.slot}")
            return False
        
        if self.equipment[item.slot]:
            self.inventory.append(self.equipment[item.slot])
        
        self.equipment[item.slot] = item
        if item in self.inventory:
            self.inventory.remove(item)
        
        print(f"Экипировано: {item.name}")
        return True
    
    def level_up(self):
        self.level += 1
        self.xp -= self.xp_to_level
        self.xp_to_level *= 2
        
        print(f"\n=== {self.name} достиг {self.level} уровня! ===")
        print("Выберите характеристику для улучшения:")
        print("1. Сила (+1 к урону)")
        print("2. Здоровье (+5 к максимальному HP)")
        print("3. Защита (+1 к защите)")
        print("4. Крит (+1% к шансу крита)")
        print("5. Уворот (+1% к шансу уворота)")
        
        choice = input("Ваш выбор (1-5): ")
        if choice == "1":
            self.base_min_dmg += 1
            self.base_max_dmg += 1
            print("Сила увеличена! Урон +1")
        elif choice == "2":
            self.max_hp += 5
            self.hp += 5
            print("Здоровье увеличено! Максимальное HP +5")
        elif choice == "3":
            self.base_defense += 1
            print("Защита увеличена! +1 к защите")
        elif choice == "4":
            self.crit_chance += 1
            print("Шанс крита увеличен! +1%")
        elif choice == "5":
            self.dodge_chance += 1
            print("Шанс уворота увеличен! +1%")
        else:
            print("Неверный выбор, защита увеличена по умолчанию")
            self.base_defense += 1
    
    def show_status(self):
        print(f"\n=== Статус {self.name} ===")
        print(f"Уровень: {self.level} (Опыт: {self.xp}/{self.xp_to_level})")
        print(f"Здоровье: {self.hp}/{self.max_hp}")
        print(f"Урон: {self.min_dmg}-{self.max_dmg}")
        print(f"Крит: {self.crit_chance_total}%")
        print(f"Уворот: {self.dodge_chance_total}%")
        print(f"Защита: {self.defense} (-{self.defense} к урону)")
        print(f"Ключи подземелья: {self.dungeon_keys}")
        
        print("\nЭкипировка:")
        for slot, item in self.equipment.items():
            print(f"{slot.capitalize()}: {item.name if item else 'Пусто'}")
        
        print("\nСпутники:")
        if self.companions:
            for companion in self.companions:
                print(f"{companion.name} (HP: {companion.hp}/{companion.max_hp})")
                
        else:
            print("Нет спутников")
        
        print("\nАктивные эффекты:")
        for effect_name, effects in self.active_effects.items():
            for effect in effects:
                print(f"{effect_name}: {effect['duration']} ходов осталось")

        print(f"\nЗолото: {self.gold}")
        print("====================\n")

class Companion:
    def __init__(self, name, max_hp, min_dmg, max_dmg, cost):
        self.name = name
        self.max_hp = max_hp
        self.hp = max_hp
        self.min_dmg = min_dmg
        self.max_dmg = max_dmg
        self.cost = cost
    
    def attack(self):
        return random.randint(self.min_dmg, self.max_dmg)
    
    def take_damage(self, damage):
        self.hp -= damage
        return damage
    
    def is_alive(self):
        return self.hp > 0
    
    def heal_full(self):
        self.hp = self.max_hp

class Item:
    def __init__(self, name, item_type, slot, required_level, stats):
        self.name = name
        self.type = item_type
        self.slot = slot
        self.required_level = required_level
        self.stats = stats

class Shield(Item):
    def __init__(self, name, required_level, block_chance, defense):
        super().__init__(name, 'shield', 'shield', required_level, 
                        {'block_chance': block_chance, 'defense': defense})
        self.block_chance = block_chance

