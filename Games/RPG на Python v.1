def battle(hero, monsters):
    print(f"\n=== Бой с {len(monsters)} противниками ===")
    for i, monster in enumerate(monsters, 1):
        print(f"{i}. {monster.name} (Ур. {monster.level}): HP={monster.hp}, Урон={monster.min_dmg}-{monster.max_dmg}")
        print(f"   Способность: {monster.ability}")
    
    turn = 0
    while hero.is_alive() and any(m.is_alive() for m in monsters):
        turn += 1
        print(f"\n=== Ход {turn} ===")
        
        hero.update_effects()
        
        dead_companions = [c for c in hero.companions if not c.is_alive()]
        for companion in dead_companions:
            print(f"{companion.name} пал в бою и возвращен в таверну!")
            companion.heal_full()
            hero.companions.remove(companion)
            hero.available_companions.append(companion)
        
        print("\nВаш ход:")
        print("1. Атаковать")
        print("2. Использовать предмет")
        
        choice = input("Выберите действие: ")
        
        if choice == "1":
            alive_monsters = [m for m in monsters if m.is_alive()]
            print("Выберите цель:")
            for i, monster in enumerate(alive_monsters, 1):
                print(f"{i}. {monster.name} (HP: {monster.hp})")
            
            try:
                target_idx = int(input()) - 1
                if 0 <= target_idx < len(alive_monsters):
                    target = alive_monsters[target_idx]
                    hero_dmg = hero.attack()
                    target.take_damage(hero_dmg)
                    print(f"{hero.name} атакует {target.name} и наносит {hero_dmg} урона!")
                else:
                    print("Неверный выбор, атакуете первого монстра!")
                    target = alive_monsters[0]
                    hero_dmg = hero.attack()
                    target.take_damage(hero_dmg)
                    print(f"{hero.name} атакует {target.name} и наносит {hero_dmg} урона!")
            except ValueError:
                print("Неверный ввод, атакуете первого монстра!")
                target = alive_monsters[0]
                hero_dmg = hero.attack()
                target.take_damage(hero_dmg)
                print(f"{hero.name} атакует {target.name} и наносит {hero_dmg} урона!")
            
            for companion in hero.companions:
                if companion.is_alive() and any(m.is_alive() for m in monsters):
                    alive_monsters = [m for m in monsters if m.is_alive()]
                    target = random.choice(alive_monsters)
                    dmg = companion.attack()
                    target.take_damage(dmg)
                    print(f"{companion.name} атакует {target.name} и наносит {dmg} урона!")
        
        elif choice == "2":
            show_inventory(hero)
            continue
        else:
            print("Неверный выбор, пропускаете ход!")
        
        if not any(m.is_alive() for m in monsters):
            break
        
        print("\nХод монстров:")
        for monster in monsters:
            if monster.is_alive():
                targets = [hero] + [c for c in hero.companions if c.is_alive()]
                target = random.choice(targets)
                
                monster_dmg = monster.attack()
                actual_damage = target.take_damage(monster_dmg)
                
                if isinstance(target, Hero):
                    print(f"{monster.name} атакует {target.name} и наносит {actual_damage} урона!")
                else:
                    print(f"{monster.name} атакует {target.name} и наносит {actual_damage} урона!")
        
        print(f"\n{hero.name}: HP={hero.hp}")
        for companion in hero.companions:
            if companion.is_alive():
                print(f"{companion.name}: HP={companion.hp}")
        for monster in monsters:
            if monster.is_alive():
                print(f"{monster.name}: HP={monster.hp}")
        
        time.sleep(1)
    
    if hero.is_alive():
        total_gold = sum(m.gold_reward for m in monsters)
        
        total_xp = sum(m.xp_reward for m in monsters)
        hero.gold += total_gold
        hero.xp += total_xp

        print(f"\nПобеда! Вы получили {total_gold} золота и {total_xp} опыта!")
        
        for monster in monsters:
            if random.random() < 0.4:
                possible_items = [i for i in all_items if i.required_level <= hero.level]
                if possible_items:
                    item = random.choice(possible_items)
                    hero.add_item(item)
        
        if hero.xp >= hero.xp_to_level:
            hero.level_up()
        return True
    else:
        print("\nВы потерпели поражение...")
        return False

def dungeon_exploration(hero):
    print("\n=== Вход в подземелье ===")
    print("Вы спускаетесь в темное подземелье, полное опасностей...")
    time.sleep(2)
    
    total_floors = 10
    hero.current_dungeon_floor = 1
    
    while hero.current_dungeon_floor <= total_floors and hero.is_alive():
        print(f"\n=== Этаж {hero.current_dungeon_floor}/{total_floors} ===")
        found_exit = False
        
        while not found_exit and hero.is_alive():
            print("\nВыберите действие:")
            print("1. Исследовать этаж")
            print("2. Показать статус")
            print("3. Выйти из подземелья")
            
            choice = input("Ваш выбор: ")
            
            if choice == "1":
                # 5% шанс найти босса и выход
                if random.random() <= 0.05:
                    boss, key_name = create_dungeon_boss(hero.current_dungeon_floor)
                    print(f"\nВы нашли проход на следующий этаж, но его охраняет {boss.name}!")
                    print(f"Способность босса: {boss.ability}")
                    
                    if battle(hero, [boss]):
                        hero.dungeon_keys += 1
                        print(f"\nВы победили {boss.name} и получили {key_name}!")
                        found_exit = True
                else:
                    # 50% шанс встретить монстров, иначе случайное событие
                    if random.random() <= 0.5:
                        monsters = create_monster_pack(hero.level)
                        print("\nВы встретили группу монстров!")
                        if not battle(hero, monsters):
                            break
                    else:
                        event_result = dungeon_event(hero, hero.current_dungeon_floor)
                        if event_result:  # Если событие вернуло монстров
                            if not battle(hero, event_result):
                                break
            
            elif choice == "2":
                hero.show_status()
            
            elif choice == "3":
                print("\nВы покидаете подземелье...")
                return False
            
            else:
                print("Неверный выбор. Попробуйте снова.")
        
        if found_exit and hero.is_alive():
            if hero.current_dungeon_floor == total_floors:
                print("\n=== ПОБЕДА ===")
                print("Вы достигли глубины подземелья и победили Некроманта!")
                print("Принцесса спасена, а Император щедро наградил вас!")
                print("Спасибо за игру!")
                return True
            
            # Отдых между этажами
            heal_amount = hero.max_hp // 4
            hero.heal(heal_amount)
            for companion in hero.companions:
                if companion.is_alive():
                    companion.heal_full()
            print(f"\nВы немного отдохнули и восстановили {heal_amount} HP.")
            time.sleep(1)
            
            hero.current_dungeon_floor += 1
    
    if not hero.is_alive():
        print("\nВаше приключение в подземелье закончилось неудачей...")
        hero.hp = max(hero.hp, hero.max_hp // 2)
        for companion in hero.companions:
            companion.hp = max(companion.hp, companion.max_hp // 2)
        return False
    
    return False


def show_inventory(hero):
    while True:
        print("\n=== Инвентарь ===")
        if not hero.inventory:
            print("Инвентарь пуст")
            return
        
        for i, item in enumerate(hero.inventory, 1):
            req_level = f" (ур. {item.required_level})" if item.required_level > 1 else ""
            value = ""
            if item.type in ['weapon', 'shield', 'armor', 'ring', 'amulet']:
                value = f" - Цена: {item.required_level * 20}"
            elif item.type == 'potion':
                value = f" - Цена: {item.required_level * 10}"
            print(f"{i}. {item.name}{req_level} ({item.type}){value}")
        
        print("\nВыберите действие:")
        print("1. Использовать предмет")
        print("2. Продать предмет")
        print("0. Выйти")
        
        choice = input("Ваш выбор: ")
        
        if choice == "1":
            print("\nВыберите предмет для использования (или 0 для отмены):")
            try:
                item_idx = int(input()) - 1
                if item_idx == -1:
                    continue
                if 0 <= item_idx < len(hero.inventory):
                    use_item(hero, hero.inventory[item_idx])
                else:
                    print("Неверный выбор!")
            except ValueError:
                print("Введите число!")
        elif choice == "2":
            print("\nВыберите предмет для продажи (или 0 для отмены):")
            try:
                item_idx = int(input()) - 1
                if item_idx == -1:
                    continue
                if 0 <= item_idx < len(hero.inventory):
                    sell_item(hero, hero.inventory[item_idx])
                else:
                    print("Неверный выбор!")
            except ValueError:
                print("Введите число!")
        elif choice == "0":
            return
        else:
            print("Неверный выбор!")

def use_item(hero, item):
    if item.type == 'potion':
        if 'heal' in item.stats:
            heal_amount = min(item.stats['heal'], hero.max_hp - hero.hp)
            if heal_amount > 0:
                hero.heal(heal_amount)
                hero.inventory.remove(item)
                print(f"Использовано зелье здоровья. Восстановлено {heal_amount} HP.")
            else:
                print("Ваше здоровье уже максимально!")
        elif 'duration' in item.stats:
            effect_name = item.name.replace("Зелье ", "").replace("Эликсир ", "")
            effect_stats = {k: v for k, v in item.stats.items() if k != 'duration'}
            hero.add_effect(effect_name, item.stats['duration'], **effect_stats)
            hero.inventory.remove(item)
            print(f"Использовано {item.name}. Эффект активен {item.stats['duration']} ходов.")
    elif item.type == 'key':
        hero.dungeon_keys += 1
        hero.inventory.remove(item)
        print("Вы получили ключ от подземелья!")
    elif item.slot:
        hero.equip_item(item)
    else:
        print("Этот предмет нельзя использовать.")

def sell_item(hero, item):
    if item.type in ['weapon', 'shield', 'armor', 'ring', 'amulet']:
        price = item.required_level * 20
    elif item.type == 'potion':
        price = item.required_level * 10
    elif item.type == 'treasure' and 'gold' in item.stats:
        price = item.stats['gold']
    else:
        print("Этот предмет нельзя продать.")
        return
    
    hero.gold += price
    hero.inventory.remove(item)
    print(f"Вы продали {item.name} за {price} золота!")


def shop(hero):
    available_items = [item for item in all_items 
                      if item.required_level <= hero.level + 2 and 
                      item.type in ['potion', 'weapon', 'shield', 'armor', 'ring', 'amulet']]
    
    if not available_items:
        print("Магазин пуст, зайдите позже!")
        return
    
    prices = []
    for item in available_items:
        base_price = item.required_level * 20
        if item.type == 'potion':
            price = base_price // 2
        elif item.type in ['ring', 'amulet']:
            price = base_price * 2
        else:
            price = base_price
        prices.append(price)
    
    print("\n=== Магазин ===")
    print(f"Ваше золото: {hero.gold}")
    for i, (item, price) in enumerate(zip(available_items, prices), 1):
        stats = ""
        if item.type == 'weapon':
            stats = f"Урон: {item.stats['min_dmg']}-{item.stats['max_dmg']} (ур. {item.required_level})"
        elif item.type == 'shield':
            stats = f"Защита: {item.stats['defense']}, Блок: {item.stats['block_chance']}% (ур. {item.required_level})"
        elif item.type == 'armor':
            stats = f"Защита: {item.stats['defense']} (ур. {item.required_level})"
        elif item.type == 'boots':
            stats = f"Защита: {item.stats['defense']}, Уворот: {item.stats['dodge']}% (ур. {item.required_level})"
        elif item.type == 'ring' or item.type == 'amulet':
            stats = []
            if 'crit' in item.stats:
                stats.append(f"Крит: +{item.stats['crit']}%")
            if 'dodge' in item.stats:
                stats.append(f"Уворот: +{item.stats['dodge']}%")
            if 'defense' in item.stats:
                stats.append(f"Защита: +{item.stats['defense']}")
            stats = f"{', '.join(stats)} (ур. {item.required_level})"
        elif item.type == 'potion':
            if 'heal' in item.stats:
                stats = f"Восстанавливает {item.stats['heal']} HP (ур. {item.required_level})"
            else:
                effects = []
                for stat, value in item.stats.items():
                    if stat != 'duration':
                        effects.append(f"+{value} к {'урону' if 'dmg' in stat else stat}")
                stats = f"{', '.join(effects)} на {item.stats['duration']} ходов (ур. {item.required_level})"
        
        print(f"{i}. {item.name} - {price} золота ({stats})")
    
    print("0. Выйти из магазина")
    
    print("\nВыберите предмет для покупки:")
    try:
        choice = int(input()) - 1
        if choice == -1:
            return
        if 0 <= choice < len(available_items):
            if hero.gold >= prices[choice]:
                hero.gold -= prices[choice]
                hero.add_item(available_items[choice])
                print(f"Куплено: {available_items[choice].name}")
            else:
                print("Недостаточно золота!")
        else:
            print("Неверный выбор!")
    except ValueError:
        print("Введите число!")


def tavern(hero):
    print("\n=== Таверна 'Упрямый гном' ===")
    print("Здесь можно нанять верных спутников для ваших приключений.")
    print(f"Ваше золото: {hero.gold}")
    print("Доступные спутники:")
    
    if not hero.available_companions:
        print("Нет доступных спутников для найма.")
        return
    
    for i, companion in enumerate(hero.available_companions, 1):
        print(f"{i}. {companion.name} (HP: {companion.max_hp}, Урон: {companion.min_dmg}-{companion.max_dmg}) - {companion.cost} золота")
    
    print("0. Выйти из таверны")
    
    print("\nВыберите спутника для найма:")
    try:
        choice = int(input()) - 1
        if choice == -1:
            return
        if 0 <= choice < len(hero.available_companions):
            companion = hero.available_companions[choice]
            if hero.gold >= companion.cost:
                hero.gold -= companion.cost
                hero.companions.append(companion)
                hero.available_companions.remove(companion)
                print(f"Вы наняли {companion.name}!")
            else:
                print("Недостаточно золота!")
        else:
            print("Неверный выбор!")
    except ValueError:
        print("Введите число!")

def main():
    hero = Hero()
    print("=== Спасение принцессы ===")
