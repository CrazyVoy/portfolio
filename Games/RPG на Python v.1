def create_monster_pack(hero_level):
    """Создает группу монстров с учетом уровня героя"""
    monster_count = random.choices(
        [1, 2, 3, 4],
        weights=[80, 12.5, 5, 2.5]
    )[0]
    
    monsters = []
    for _ in range(monster_count):
        monster_level = random.choices(
            [hero_level-1, hero_level, hero_level+1, random.randint(3, 9)],
            weights=[20, 60, 10, 10]
        )[0]
        monster_level = max(1, min(10, monster_level))
        
        if monster_level == 1:
            monster_types = [
                ("Гоблин", "Может бросить камень (доп. урон)"),
                ("Крыса", "Отравленный укус (урон каждый ход)"),
                ("Паук", "Паутина (шанс обездвижить)")
            ]
        elif monster_level == 2:
            monster_types = [
                ("Скелет", "Устойчив к критическим ударам"),
                ("Волк", "Стайный инстинкт (урон увеличивается при атаке группой)"),
                ("Бандит", "Грязный прием (шанс оглушить)")
            ]
        elif monster_level == 3:
            monster_types = [
                ("Орк", "Ярость: при низком HP урон увеличивается"),
                ("Тролль", "Регенерация: восстанавливает HP каждый ход"),
                ("Гарпия", "Атака с воздуха (игнорирует часть защиты)")
            ]
        elif monster_level == 4:
            monster_types = [
                ("Призрак", "Может проходить сквозь блоки"),
                ("Зомби", "Медленный, но выносливый"),
                ("Гаргойль", "Каменная кожа (уменьшает получаемый урон)")
            ]
        elif monster_level == 5:
            monster_types = [
                ("Вампир", "Лечится за счет нанесенного урона"),
                ("Оборотень", "Превращение (увеличивает урон ночью)"),
                ("Элементаль", "Стихийный урон (дополнительный эффект)")
            ]
        elif monster_level == 6:
            monster_types = [
                ("Демон", "Поджигает противника (доп. урон каждый ход)"),
                ("Минотавр", "Таран (шанс оглушить)"),
                ("Химера", "Мультиатака (атакует несколько раз)")
            ]
        elif monster_level == 7:
            monster_types = [
                ("Лич", "Воскрешает павших союзников"),
                ("Драконид", "Драконья кровь (устойчивость к магии)"),
                ("Голем", "Нежить (нечувствителен к боли)")
            ]
        elif monster_level == 8:
            monster_types = [
                ("Древний дракон", "Огненное дыхание (урон по всей группе)"),
                ("Темный рыцарь", "Темная аура (снижает защиту противников)"),
                ("Архидемон", "Проклятие (накладывает негативные эффекты)")
            ]
        elif monster_level == 9:
            monster_types = [
                ("Повелитель тьмы", "Насылает проклятия на противников"),
                ("Король демонов", "Призыв демонов (увеличивает число противников)"),
                ("Архилич", "Темная магия (наносит урон и снижает характеристики)")
            ]
        else:
            monster_types = [
                ("Некромант", "Воскрешает мертвецов и насылает темную магию"),
                ("Повелитель смерти", "Крадет души (уменьшает максимальное HP)"),
                
                ("Верховный дракон", "Стихийные атаки (огонь, лед, молния)")
            ]
        
        name, ability = random.choice(monster_types)
        
        hp = 30 + (monster_level - 1) * 15
        min_dmg = 5 + (monster_level - 1) * 2
        max_dmg = 8 + (monster_level - 1) * 3
        
        if monster_level >= 7:
            hp += 20
            min_dmg += 3
            max_dmg += 5
        
        xp_reward = 15 + monster_level * 8
        gold_reward = 10 + monster_level * 5
        
        monsters.append(Monster(name, hp, min_dmg, max_dmg, xp_reward, gold_reward, ability))
    
    return monsters

class Monster:
    def __init__(self, name, hp, min_dmg, max_dmg, xp_reward, gold_reward, ability):
        self.name = name
        self.hp = hp
        self.min_dmg = min_dmg
        self.max_dmg = max_dmg
        self.xp_reward = xp_reward
        self.gold_reward = gold_reward
        self.ability = ability
        self.level = min(10, max(1, (hp // 10) - 1))
    
    def attack(self):
        return random.randint(self.min_dmg, self.max_dmg)
    
    def take_damage(self, damage):
        self.hp -= damage
        return damage
    
    def is_alive(self):
        return self.hp > 0

