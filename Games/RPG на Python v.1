    starter_items = [
        Item("Деревянная палка", 'weapon', 'weapon', 1, {'min_dmg': 1, 'max_dmg': 3}),
        Item("Тряпье", 'armor', 'armor', 1, {'defense': 1}),
        Item("Дырявые носки", 'armor', 'boots', 1, {'defense': 0, 'dodge': 1}),
        Item("Зелье здоровья", 'potion', None, 1, {'heal': 30})
    ]
    for item in starter_items:
        hero.inventory.append(item)
    
    while True:
        hero.show_status()
        print("1. Охота на монстров (тренировка)")
        print("2. Исследовать подземелье (основной квест)")
        print("3. Посмотреть инвентарь")
        print("4. Посетить магазин")
        print("5. Заглянуть в таверну")
        print("6. Выйти из игры")
        
        choice = input("Выберите действие: ")
        
        if choice == "1":
            monsters = create_monster_pack(hero.level)
            print("\nВы отправились на охоту...")
            if not battle(hero, monsters):
                hero.hp = hero.max_hp // 2
                for companion in hero.companions:
                    companion.hp = companion.max_hp // 2
                print("Вы чудом выжили и восстановили половину здоровья.")
        elif choice == "2":
            if hero.level < 3:
                print("Подземелья слишком опасны! Вернитесь после 3 уровня.")
            else:
                if dungeon_exploration(hero):
                    break
        elif choice == "3":
            show_inventory(hero)
        elif choice == "4":
            shop(hero)
        elif choice == "5":
            tavern(hero)
        elif choice == "6":
            print("Вы покидаете игру... Принцесса так и останется в плену у Некроманта.")
            break
        else:
            print("Неверный выбор. Попробуйте снова.")

if __name__ == "__main__":
    all_items = create_items()
    main()
